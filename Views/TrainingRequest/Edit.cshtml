<!-- ✅ jQuery (Select2 ต้องใช้) -->
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<!-- ✅ Select2 JS -->
<script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
<!-- ✅ Flatpickr JS -->
<script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>

<script>
        // ====================================================================
        // 🔒 Read-only Mode - Disable ฟิลด์ทั้งหมดถ้า User ไม่สามารถแก้ไขได้
        // ====================================================================
        const canEdit = @(canEdit.ToString().ToLower());
        const isApproveMode = @(isApproveMode.ToString().ToLower());  // ⭐ เพิ่มบรรทัดนี้

        if (!canEdit) {
            console.log('🔒 Read-only Mode: Disabling form fields (Approve Mode: ' + isApproveMode + ')');

            // ⭐ Disable input, select, textarea ทั้งหมด (ยกเว้น readonly และ approvalComment ในโหมดอนุมัติ)
            document.querySelectorAll('input:not([readonly]), select:not([readonly]), textarea:not([readonly])').forEach(el => {
                // ⭐ ยกเว้น approvalComment ถ้าอยู่ในโหมดอนุมัติ
                if (isApproveMode && el.id === 'approvalComment') {
                    return; // ไม่ disable comment box
                }

                el.disabled = true;
                el.style.cursor = 'not-allowed';
            });

            // ⭐ แก้ไข: Disable buttons แต่ยกเว้นปุ่มอนุมัติถ้าอยู่ในโหมดอนุมัติ
            document.querySelectorAll('button:not([data-bs-dismiss])').forEach(btn => {
                // ยกเว้นปุ่มในกรณีต่อไปนี้:
                // 1. ปุ่มอยู่ใน alert
                // 2. ปุ่มกลับ (btn-secondary)
                // 3. ⭐ ปุ่มอนุมัติ (btnApprove, btnRevise, btnReject) ถ้าอยู่ในโหมดอนุมัติ
                const isApprovalButton = btn.id === 'btnApprove' || btn.id === 'btnRevise' || btn.id === 'btnReject';
                const shouldSkip = btn.closest('.alert') ||
                                  btn.classList.contains('btn-secondary') ||
                                  (isApproveMode && isApprovalButton);  // ⭐ เพิ่มเงื่อนไขนี้

                if (!shouldSkip) {
                    btn.disabled = true;
                    btn.style.cursor = 'not-allowed';
                }
            });

            console.log('✅ Form fields disabled. Approval buttons: ' + (isApproveMode ? 'ENABLED' : 'DISABLED'));

            // ⭐ Debug log สำหรับ Approve Mode
            if (isApproveMode) {
                console.log('✅ Approve Mode: Approval buttons and comment should be ENABLED');
                setTimeout(() => {
                    console.log('   - #btnApprove disabled:', document.getElementById('btnApprove')?.disabled);
                    console.log('   - #btnRevise disabled:', document.getElementById('btnRevise')?.disabled);
                    console.log('   - #btnReject disabled:', document.getElementById('btnReject')?.disabled);
                    console.log('   - #approvalComment disabled:', document.getElementById('approvalComment')?.disabled);
                    console.log('   - #approvalComment readonly:', document.getElementById('approvalComment')?.readOnly);
                }, 100);
            }
        }

        // ====================================================================
        // ✅ Re-enable HRD Section (ถ้า user มีสิทธิ์ canEditHRDSection)
        // เมื่อ canEdit=false แต่ canEditHRDSection=true, global script จะ disable
        // ทุก input รวมถึง HRD fields → ต้อง re-enable HRD fields กลับมา
        // ====================================================================
        if (!canEdit && window.__canEditHRDSection) {
            console.log('🔓 Re-enabling HRD section fields (canEditHRDSection=true)');
            var hrdCard = document.querySelector('.card.border-warning');
            if (hrdCard) {
                hrdCard.querySelectorAll('input, select, textarea').forEach(function(el) {
                    el.disabled = false;
                    el.style.cursor = '';
                });
                hrdCard.querySelectorAll('button').forEach(function(btn) {
                    btn.disabled = false;
                    btn.style.cursor = '';
                });
                // ✅ Re-enable flatpickr alt inputs ด้วย (อยู่ที่ document.body เพราะ appendTo)
                document.querySelectorAll('.flatpickr-alt-input').forEach(function(altInput) {
                    // เฉพาะ alt input ที่ sibling ของ HRD date fields
                    var prevInput = altInput.previousElementSibling;
                    if (prevInput && (prevInput.id === 'HRD_ContactDate' || prevInput.id === 'HRD_PaymentDate' || prevInput.id === 'historyDate')) {
                        altInput.disabled = false;
                        altInput.style.cursor = 'pointer';
                    }
                });
                console.log('✅ HRD section fields re-enabled');
            }
        }

        // ====================================================================
        // 🔄 Reset ค่าช่องที่ไม่ได้เลือกเป็น 0 และ Disable (แก้ไขแล้ว)
        // ====================================================================
        function resetUnusedFields() {
            const trainingType = document.querySelector('input[name="TrainingType"]:checked')?.value;

            console.log(`🔄 Training Type Changed: ${trainingType}`);

            if (trainingType === 'Public') {
                // Enable Public fields
                const publicFields = ['CostPerPerson', 'TrainingHours'];
                publicFields.forEach(id => {
                    const input = document.getElementById(id);
                    if (input) {
                        input.disabled = false;
                        console.log(`✅ Enabled: ${id}`);
                    }
                });

                // Disable In House fields
                const inHouseFields = [
                    'RegistrationCost',
                    'InstructorFee',
                    'InstructorCommission',
                    'EquipmentCost',
                    'FoodCost',
                    'OtherCost'
                ];

                inHouseFields.forEach(id => {
                    const input = document.getElementById(id);
                    if (input) {
                        input.value = '0';
                        input.disabled = true;
                        console.log(`✅ Reset & Disabled: ${id}`);
                    }
                });

                console.log('✅ Public enabled, In House disabled');

            } else if (trainingType === 'In House') {
                // Enable In House fields
                const inHouseFields = [
                    'RegistrationCost',
                    'InstructorFee',
                    'InstructorCommission',
                    'EquipmentCost',
                    'FoodCost',
                    'OtherCost'
                ];

                inHouseFields.forEach(id => {
                    const input = document.getElementById(id);
                    if (input) {
                        input.disabled = false;
                        console.log(`✅ Enabled: ${id}`);
                    }
                });

                // Disable Public fields
                const publicFields = ['CostPerPerson', 'TrainingHours'];

                publicFields.forEach(id => {
                    const input = document.getElementById(id);
                    if (input) {
                        input.value = '0';
                        input.disabled = true; // ⭐ สำคัญ! แก้ปัญหา validation
                        console.log(`✅ Reset & Disabled: ${id}`);
                    }
                });

                console.log('✅ In House enabled, Public disabled');
            }

            calculateTotalCost();
        }

        // ====================================================================
        // 💰 คำนวณยอดรวมอัตโนมัติ (Version ปรับปรุง)
        // ====================================================================
        function calculateTotalCost() {
            try {
                // ตรวจสอบประเภทการอบรมที่เลือก
                const trainingTypeRadio = document.querySelector('input[name="TrainingType"]:checked');
                const trainingType = trainingTypeRadio?.value || '';

                let total = 0;

                if (trainingType === 'Public') {
                    // ========================================
                    // 📌 Public: ค่าใช้จ่ายต่อคน × จำนวนคนในตาราง
                    // ========================================
                    const costPerPerson = parseFloat(document.getElementById('CostPerPerson')?.value || 0);

                    // ✅ Public นับจำนวนคนจากตารางพนักงาน (employeeManager.employees.length)
                    let participantCount = 0;
                    if (typeof employeeManager !== 'undefined' && employeeManager.employees) {
                        participantCount = employeeManager.employees.length;
                    }

                    // ✅ Public ต้องคูณด้วยจำนวนคน
                    total = costPerPerson * participantCount;

                    console.log('💰 Calculating Total (Public):', {
                        trainingType,
                        costPerPerson,
                        participantCount,
                        source: 'employeeManager.employees.length',
                        total: total.toFixed(2)
                    });

                } else if (trainingType === 'In House') {
                    // ========================================
                    // 📌 In House: รวมทุกค่าใช้จ่าย (ไม่คูณจำนวนคน)
                    // User กรอกค่ารวมมาแล้ว
                    // ========================================
                    const registrationCost = parseFloat(document.getElementById('RegistrationCost')?.value || 0);
                    const instructorFee = parseFloat(document.getElementById('InstructorFee')?.value || 0);
                    const instructorCommission = parseFloat(document.getElementById('InstructorCommission')?.value || 0);
                    const equipmentCost = parseFloat(document.getElementById('EquipmentCost')?.value || 0);
                    const foodCost = parseFloat(document.getElementById('FoodCost')?.value || 0);
                    const otherCost = parseFloat(document.getElementById('OtherCost')?.value || 0);

                    // ✅ In House แค่รวม ไม่ต้องคูณ
                    total = registrationCost + instructorFee + instructorCommission +
                            equipmentCost + foodCost + otherCost;

                    console.log('💰 Calculating Total (In House):', {
                        trainingType,
                        registrationCost,
                        instructorFee,
                        instructorCommission,
                        equipmentCost,
                        foodCost,
                        otherCost,
                        total: total.toFixed(2)
                    });
                }

                // ========================================
                // อัปเดตช่องแสดงผลตามประเภท
                // ========================================
                if (trainingType === 'Public') {
                    const displayPublic = document.getElementById('totalCostDisplayPublic');
                    if (displayPublic) {
                        displayPublic.textContent = total.toLocaleString('th-TH', {
                            minimumFractionDigits: 2,
                            maximumFractionDigits: 2
                        });
                    }
                } else if (trainingType === 'In House') {
                    const displayInHouse = document.getElementById('totalCostDisplay');
                    if (displayInHouse) {
                        displayInHouse.textContent = total.toLocaleString('th-TH', {
                            minimumFractionDigits: 2,
                            maximumFractionDigits: 2
                        });
                    }
                }

                // อัปเดต Hidden Input สำหรับส่งไป Backend
                const inputElement = document.getElementById('totalCostInput');
                if (inputElement) {
                    inputElement.value = total.toFixed(2);
                }

                return total;

            } catch (error) {
                console.error('❌ Error calculating total cost:', error);
                return 0;
            }
        }

        // ====================================================================
        // 🔧 ผูก Event Listeners กับทุก Input
        // ====================================================================
        function initializeBudgetCalculation() {
            console.log('🔧 Initializing budget calculation...');

            // ====================================================================
            // 🔄 Auto-clear ค่า 0 เมื่อ Focus และคืนค่า 0 เมื่อ Blur
            // ====================================================================
            const autoClearInputs = document.querySelectorAll('.budget-input, .budget-input-public, .budget-input-inhouse');

            autoClearInputs.forEach(input => {
                // Clear ค่า 0 เมื่อ Focus
                input.addEventListener('focus', function() {
                    if (this.value === '0' || this.value === '0.00') {
                        this.value = '';
                    }
                });

                // คืนค่า 0 เมื่อ Blur และไม่มีค่า
                input.addEventListener('blur', function() {
                    if (this.value.trim() === '') {
                        this.value = '0';
                    }
                });
            });

            console.log(`✅ Auto-clear setup for ${autoClearInputs.length} inputs`);

            // ====================================================================
            // รายการ Input ทั้งหมด (In House + Public)
            // ====================================================================
            const budgetInputIds = [
                // In House Fields
                'RegistrationCost',
                'InstructorFee',
                'InstructorCommission',
                'EquipmentCost',
                'FoodCost',
                'OtherCost',
                // Public Fields
                'CostPerPerson',
                'TrainingHours'
            ];

            let foundCount = 0;
            let notFoundInputs = [];

            budgetInputIds.forEach(id => {
                const input = document.getElementById(id);
                if (input) {
                    foundCount++;
                    console.log(`✅ Found & Bound: ${id}`);
                    // ผูก Event Listeners หลายแบบ
                    ['input', 'change', 'keyup', 'blur'].forEach(eventType => {
                        input.addEventListener(eventType, calculateTotalCost);
                    });
                } else {
                    notFoundInputs.push(id);
                    console.warn(`⚠️ Input not found: ${id}`);
                }
            });

            // ⭐ ผูก Event Listener กับ Training Type Radio Buttons
            const trainingTypeRadios = document.querySelectorAll('input[name="TrainingType"]');
            trainingTypeRadios.forEach(radio => {
                radio.addEventListener('change', resetUnusedFields);
                console.log(`✅ Bound Training Type: ${radio.value}`);
            });

            // สรุปผลการผูก
            console.log(`📊 Summary: ${foundCount}/${budgetInputIds.length} inputs bound`);
            console.log(`📻 Training Type radios: ${trainingTypeRadios.length} bound`);

            if (notFoundInputs.length > 0) {
                console.warn(`⚠️ Missing inputs: ${notFoundInputs.join(', ')}`);
            }

            // คำนวณครั้งแรกเมื่อโหลดหน้า
            calculateTotalCost();

            console.log('✅ Budget calculation initialized successfully!');
        }

        // ====================================================================
        // 🚀 เรียกใช้งานเมื่อ DOM พร้อม
        // ====================================================================
        if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', initializeBudgetCalculation);
        } else {
            initializeBudgetCalculation();
        }

        // ====================================================================
        // 0. Load Departments and Positions - เมื่อโหลดหน้าเสร็จ
        // ====================================================================
        // ✅ REMOVED: ย้ายไปรวมกับ DOMContentLoaded listener ด้านล่าง (บรรทัด ~2243)
        // เพื่อป้องกัน race condition และลดการเรียก API ซ้ำซ้อน

        async function loadDepartmentsAndPositions() {
            try {
                const response = await fetch('/api/employee/departments-positions');

                if (response.ok) {
                    const result = await response.json();

                    if (result.success) {
                        const departmentSelect = document.getElementById('departmentSelect');
                        if (departmentSelect && result.departments) {
                            result.departments.forEach(dept => {
                                const option = document.createElement('option');
                                option.value = dept;
                                option.textContent = dept;
                                departmentSelect.appendChild(option);
                            });
                        }

                        const positionSelect = document.getElementById('positionSelect');
                        if (positionSelect && result.positions) {
                            result.positions.forEach(pos => {
                                const option = document.createElement('option');
                                option.value = pos;
                                option.textContent = pos;
                                positionSelect.appendChild(option);
                            });
                        }

                        console.log('✅ Loaded departments:', result.departments.length);
                        console.log('✅ Loaded positions:', result.positions.length);
                    } else {
                        console.error('❌ Failed to load departments and positions');
                    }
                } else {
                    console.error('❌ API Error:', response.status);
                }
            } catch (error) {
                console.error('❌ Error loading departments and positions:', error);
            }
        }
