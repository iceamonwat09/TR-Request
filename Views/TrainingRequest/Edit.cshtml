    // ✅ คำนวณยอดคงเหลือใหม่จากโควต้าปัจจุบัน
    async recalculateFromCurrentQuota() {
        console.log('🔄 Starting recalculation from current quota...');

        const trainingType = '@Model.TrainingType'?.toUpperCase();
        const department = '@Html.Raw(Model.Department)';

        // ถ้าเป็น IN HOUSE ไม่ต้องคำนวณใหม่
        if (trainingType !== 'PUBLIC') {
            alert('การคำนวณใหม่ใช้ได้กับ PUBLIC training เท่านั้น');
            return;
        }

        if (!department) {
            alert('ไม่พบข้อมูลฝ่าย ไม่สามารถคำนวณใหม่ได้');
            return;
        }

        // ตรวจสอบว่ามีพนักงานในรายการหรือไม่
        if (!this.employees || this.employees.length === 0) {
            alert('ไม่มีพนักงานในรายการ ไม่สามารถคำนวณใหม่ได้');
            return;
        }

        try {
            // 1. ดึงข้อมูลโควต้าฝ่ายปัจจุบันจาก API (ใช้พนักงานคนแรก)
            const firstEmployee = this.employees[0];
            console.log('📡 Fetching current quota for department:', department);
            console.log('   Using employee:', firstEmployee.empCode);

            const budgetSource = document.querySelector('input[name="BudgetSource"]:checked')?.value || '';
            const url = `/api/employee/search/${firstEmployee.empCode}?department=${encodeURIComponent(department)}&trainingType=${trainingType}&budgetSource=${encodeURIComponent(budgetSource)}`;
            const response = await fetch(url);

            if (!response.ok) {
                throw new Error(`API returned ${response.status}`);
            }

            const data = await response.json();

            if (!data.success || !data.employee) {
                alert('ไม่สามารถดึงข้อมูลโควต้าฝ่ายได้');
                return;
            }

            const currentDepartmentQuota = data.employee.departmentQuota || 0;
            const currentDepartmentQhours = data.employee.departmentQhours || 0;
            const currentYearCost = data.employee.currentYearCost || 0;
            const currentYearHours = data.employee.currentYearHours || 0;

            console.log('✅ Current quota fetched:', {
                quota: currentDepartmentQuota,
                hours: currentDepartmentQhours,
                usedCost: currentYearCost,
                usedHours: currentYearHours
            });

            // 2. ตรวจสอบว่าฟอร์มนี้รวมอยู่ใน currentYearCost หรือไม่
            const currentStatus = '@Model.Status'.toUpperCase();
            const approvedStatuses = ['APPROVED', 'RESCHEDULED', 'COMPLETE'];
            const isApproved = approvedStatuses.includes(currentStatus);

            // คำนวณ departmentUsedCostExcludingThis
            let departmentUsedCostExcludingThis = currentYearCost;
            let departmentUsedHoursExcludingThis = currentYearHours;

            if (isApproved && this.totalCostUsedInForm > 0) {
                departmentUsedCostExcludingThis = currentYearCost - this.totalCostUsedInForm;
                departmentUsedHoursExcludingThis = currentYearHours - this.totalHoursUsedInForm;
            }

            console.log('📊 Department used (excluding this form):', {
                cost: departmentUsedCostExcludingThis,
                hours: departmentUsedHoursExcludingThis
            });

            // 3. คำนวณใหม่สำหรับแต่ละพนักงาน (accumulated pattern)
            let accumulatedCost = 0;
            let accumulatedHours = 0;

            this.employees.forEach((emp, index) => {
                // ✅ Fix #2: อัพเดต currentYearHours/currentYearCost ใน employee object (ค่าจาก API ใหม่ตาม BudgetSource)
                emp.currentYearHours = currentYearHours;
                emp.currentYearCost = currentYearCost;

                // คำนวณยอดคงเหลือ (accumulated)
