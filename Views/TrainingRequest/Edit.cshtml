                                    </div>
                                </div>

                                @* ==================== HRD Record Section (Admin/System Admin/HRD Admin/HRD Confirmation Only) ==================== *@
                                @{
                                    bool isHRDAdmin = string.Equals(userEmail, Model.HRDAdminId, StringComparison.OrdinalIgnoreCase);
                                    bool isHRDConfirmation = string.Equals(userEmail, Model.HRDConfirmationId, StringComparison.OrdinalIgnoreCase);
                                    bool canEditHRDSection = isAdmin ||
                                                             userRole.Contains("System Admin", StringComparison.OrdinalIgnoreCase) ||
                                                             isHRDAdmin ||
                                                             isHRDConfirmation;
                                }

                                @if (canEditHRDSection)
                                {
                                    <hr class="my-5">
                                    <div class="card shadow-sm border-warning mb-4" style="border-radius: 12px; border-width: 2px;">
                                        <div class="card-header bg-warning text-dark py-3" style="border-radius: 10px 10px 0 0;">
                                            <h5 class="mb-0 fw-bold">
                                                <i class="fa fa-clipboard-check"></i>
                                                ข้อมูลส่วน HRD บันทึกข้อมูล
                                                <small class="text-muted">(เฉพาะ Admin/System Admin/HRD Admin/HRD Confirmation)</small>
                                            </h5>
                                        </div>
                                        <div class="card-body p-4" style="background-color: #fffbf0;">
                                            @* 🔍 Debug: Log HRD Model values *@
                                            <script>
                                                window.__canEditHRDSection = true;
                                                console.log('📋 HRD Fields from Model:');
                                                console.log('   ContactDate: @Model.HRD_ContactDate');
                                                console.log('   ContactPerson: @Model.HRD_ContactPerson');
                                                console.log('   PaymentDate: @Model.HRD_PaymentDate');
                                                console.log('   PaymentMethod: @Model.HRD_PaymentMethod');
                                                console.log('   RecorderSignature: @Model.HRD_RecorderSignature');
                                            </script>

                                            <!-- ==================== การวางแผนงบประมาณ ==================== -->
                                            <div class="row g-3">
                                                <div class="col-md-12">
                                                    <label class="form-label fw-bold">📊 การวางแผนงบประมาณ:</label>
                                                    <div class="d-flex gap-4 mt-2">
                                                        <div class="form-check">
                                                            <input class="form-check-input" type="radio" name="HRD_BudgetPlan" value="Plan" id="budgetPlan"
                                                                   @(Model.HRD_BudgetPlan == "Plan" ? "checked" : "") style="transform: scale(1.2);">
                                                            <label class="form-check-label fw-medium" for="budgetPlan">Plan</label>
                                                        </div>
                                                        <div class="form-check">
                                                            <input class="form-check-input" type="radio" name="HRD_BudgetPlan" value="Unplan" id="budgetUnplan"
                                                                   @(Model.HRD_BudgetPlan == "Unplan" ? "checked" : "") style="transform: scale(1.2);">
                                                            <label class="form-check-label fw-medium" for="budgetUnplan">Unplan</label>
                                                        </div>
                                                    </div>
                                                </div>

                                                <!-- ==================== การใช้งบประมาณ ==================== -->
                                                <div class="col-md-12">
                                                    <label class="form-label fw-bold">💰 การใช้งบประมาณ:</label>
                                                    <div class="d-flex gap-4 align-items-center mt-2 flex-wrap">
                                                        <div class="form-check">
                                                            <input class="form-check-input" type="radio" name="HRD_BudgetUsage" value="TYP" id="budgetTYP"
                                                                   @(Model.HRD_BudgetUsage == "TYP" ? "checked" : "") style="transform: scale(1.2);">
                                                            <label class="form-check-label fw-medium" for="budgetTYP">ใช้งบประมาณตามแผน TYP</label>
                                                        </div>
                                                        <div class="form-check d-flex align-items-center gap-2">
                                                            <input class="form-check-input" type="radio" name="HRD_BudgetUsage" value="Department" id="budgetDept"
                                                                   @(Model.HRD_BudgetUsage == "Department" ? "checked" : "") style="transform: scale(1.2);">
                                                            <label class="form-check-label fw-medium" for="budgetDept">ใช้งบต้นสังกัด คงเหลือ</label>
                                                            <input type="text" class="form-control form-control-sm" id="hrdDeptBudgetRemaining" name="HRD_DepartmentBudgetRemaining"
                                                                   value="@(Model.HRD_DepartmentBudgetRemaining?.ToString("N2") ?? "0")"
                                                                   style="max-width: 150px; border-radius: 8px; text-align: right;"
                                                                   @(Model.HRD_BudgetUsage == "TYP" ? "" : "readonly")>
                                                            <span class="fw-medium">บาท</span>
                                                        </div>
                                                    </div>
                                                </div>

                                                <!-- ==================== การเป็นสมาชิก/สิทธิพิเศษ ==================== -->
                                                <div class="col-md-12">
                                                    <label class="form-label fw-bold">🏷️ การเป็นสมาชิก/สิทธิพิเศษ:</label>
                                                    <div class="d-flex gap-4 align-items-center mt-2 flex-wrap">
                                                        <div class="form-check d-flex align-items-center gap-2">
                                                            <input class="form-check-input" type="radio" name="HRD_MembershipType" value="Member" id="memberYes"
                                                                   @(Model.HRD_MembershipType == "Member" ? "checked" : "") style="transform: scale(1.2);">
                                                            <label class="form-check-label fw-medium" for="memberYes">เป็นสมาชิก</label>
                                                            <input type="number" step="0.01" class="form-control form-control-sm membership-cost-input" id="memberCost"
                                                                   style="max-width: 150px; border-radius: 8px; text-align: right;"
                                                                   @(Model.HRD_MembershipType == "Member" ? $"value={Model.HRD_MembershipCost?.ToString("F2") ?? ""}" : "disabled")>
                                                            <span class="fw-medium">บาท</span>
                                                        </div>
                                                        <div class="form-check d-flex align-items-center gap-2">
                                                            <input class="form-check-input" type="radio" name="HRD_MembershipType" value="NonMember" id="memberNo"
                                                                   @(Model.HRD_MembershipType == "NonMember" ? "checked" : "") style="transform: scale(1.2);">
                                                            <label class="form-check-label fw-medium" for="memberNo">ไม่เป็นสมาชิก</label>
                                                            <input type="number" step="0.01" class="form-control form-control-sm membership-cost-input" id="nonMemberCost"
                                                                   style="max-width: 150px; border-radius: 8px; text-align: right;"
                                                                   @(Model.HRD_MembershipType == "NonMember" ? $"value={Model.HRD_MembershipCost?.ToString("F2") ?? ""}" : "disabled")>
                                                            <span class="fw-medium">บาท</span>
                                                        </div>
                                                    </div>
                                                    <input type="hidden" name="HRD_MembershipCost" id="hrdMembershipCostHidden" value="@(Model.HRD_MembershipCost?.ToString("F2") ?? "")">
                                                </div>
                                            </div>

                                            <hr class="my-4">

                                            <!-- ==================== ประวัติการอบรม (ตาราง) ==================== -->
                                            <div>
                                                <div class="d-flex justify-content-between align-items-center mb-3">
                                                    <label class="form-label fw-bold mb-0">📋 ประวัติการอบรม: <span class="text-muted">จากการตรวจสอบประวัติการฝึกอบรมของพนักงานพบว่า (กรณีมีจำนวนมากให้แนบเอกสารเพิ่มได้)</span></label>
                                                    <button type="button" class="btn btn-sm btn-primary" id="btnAddTrainingHistory" data-bs-toggle="modal" data-bs-target="#trainingHistoryModal" style="border-radius: 20px;">
                                                        <i class="fas fa-plus me-1"></i> เพิ่ม
                                                    </button>
                                                </div>
                                                <div class="table-responsive">
                                                    <table class="table table-bordered table-hover mb-0" id="trainingHistoryTable" style="font-size: 0.9rem;">
                                                        <thead class="table-primary">
                                                            <tr>
                                                                <th class="text-center" style="width: 50px;">ที่</th>
                                                                <th class="text-center" style="min-width: 100px;">รหัสพนักงาน</th>
                                                                <th class="text-center" style="min-width: 150px;">ชื่อ - สกุล</th>
                                                                <th class="text-center" style="width: 80px;">ไม่เคย</th>
                                                                <th class="text-center" style="width: 80px;">เคย</th>
                                                                <th class="text-center" style="width: 80px;">ใกล้เคียง</th>
                                                                <th class="text-center" style="min-width: 120px;">เมื่อวันที่</th>
                                                                <th class="text-center" style="min-width: 200px;">ชื่อหลักสูตร</th>
                                                                <th class="text-center" style="width: 80px;">จัดการ</th>
                                                            </tr>
                                                        </thead>
                                                        <tbody id="trainingHistoryTableBody">
                                                            @if (Model.TrainingHistories != null && Model.TrainingHistories.Count > 0)
                                                            {
                                                                var rowIndex = 1;
                                                                foreach (var history in Model.TrainingHistories)
                                                                {
                                                                    <tr data-id="@history.Id">
                                                                        <td class="text-center align-middle">@rowIndex</td>
                                                                        <td class="text-center align-middle">@history.EmployeeCode</td>
                                                                        <td class="align-middle">@history.EmployeeName</td>
                                                                        <td class="text-center align-middle">
                                                                            <input type="checkbox" class="form-check-input" disabled @(history.HistoryType == "Never" ? "checked" : "")>
                                                                        </td>
                                                                        <td class="text-center align-middle">
                                                                            <input type="checkbox" class="form-check-input" disabled @(history.HistoryType == "Ever" ? "checked" : "")>
                                                                        </td>
                                                                        <td class="text-center align-middle">
                                                                            <input type="checkbox" class="form-check-input" disabled @(history.HistoryType == "Similar" ? "checked" : "")>
                                                                        </td>
                                                                        <td class="text-center align-middle">@history.TrainingDate?.ToString("dd/MM/yyyy")</td>
                                                                        <td class="align-middle">@history.CourseName</td>
                                                                        <td class="text-center align-middle">
                                                                            <button type="button" class="btn btn-sm btn-outline-danger btn-remove-history" title="ลบ">
                                                                                <i class="fas fa-trash"></i>
                                                                            </button>
                                                                        </td>
                                                                    </tr>
                                                                    rowIndex++;
                                                                }
                                                            }
                                                        </tbody>
                                                    </table>
                                                </div>
                                                <input type="hidden" name="TrainingHistoryJson" id="trainingHistoryJson" value="">
                                            </div>

                                            <hr class="my-4">

                                            <!-- ==================== HRD Section: ติดต่อสถาบัน/การชำระเงิน/การดำเนินงาน (ย้ายมาจากด้านบน) ==================== -->
                                            <div class="row g-3">
                                                <!-- ติดต่อสถาบัน -->
                                                <div class="col-md-6">
                                                    <label asp-for="HRD_ContactDate" class="form-label fw-bold">
                                                        📞 ติดต่อสถาบัน/ผู้สอน : วันที่
                                                    </label>
                                                    <input asp-for="HRD_ContactDate" id="HRD_ContactDate" name="HRD_ContactDate" type="text" class="form-control form-control-lg"
                                                           value="@Model.HRD_ContactDate?.ToString("yyyy-MM-dd")" placeholder="dd/mm/yyyy" style="border-radius: 8px;" />
                                                </div>

                                                <!-- ชื่อผู้ติดต่อ -->
                                                <div class="col-md-6">
                                                    <label asp-for="HRD_ContactPerson" class="form-label fw-bold">
                                                        👤 ชื่อผู้ที่ติดต่อด้วย
                                                    </label>
                                                    <input asp-for="HRD_ContactPerson" name="HRD_ContactPerson" type="text" class="form-control form-control-lg"
                                                           value="@Model.HRD_ContactPerson" placeholder="ระบุชื่อผู้ติดต่อ" style="border-radius: 8px;" />
                                                </div>

                                                <!-- การชำระเงิน -->
                                                <div class="col-md-6">
                                                    <label asp-for="HRD_PaymentDate" class="form-label fw-bold">
                                                        💰 การชำระเงิน : ชำระเงินภายในวันที่
                                                    </label>
                                                    <input asp-for="HRD_PaymentDate" id="HRD_PaymentDate" name="HRD_PaymentDate" type="text" class="form-control form-control-lg"
                                                           value="@Model.HRD_PaymentDate?.ToString("yyyy-MM-dd")" placeholder="dd/mm/yyyy" style="border-radius: 8px;" />
                                                </div>

                                                <!-- วิธีชำระเงิน (3 ช่อง: เช็ค, โอนเงิน, เงินสด) -->
                                                <div class="col-md-6">
                                                    <label class="form-label fw-bold">💳 วิธีชำระเงิน</label>
                                                    <div class="d-flex gap-3 mt-2">
                                                        <div class="form-check">
                                                            <input class="form-check-input" type="radio"
                                                                   name="HRD_PaymentMethod" asp-for="HRD_PaymentMethod"
                                                                   value="Check" id="payCheck"
                                                                   @(Model.HRD_PaymentMethod == "Check" ? "checked" : "")
                                                                   style="transform: scale(1.2);">
                                                            <label class="form-check-label fw-medium" for="payCheck">
                                                                เช็ค
                                                            </label>
                                                        </div>
                                                        <div class="form-check">
                                                            <input class="form-check-input" type="radio"
                                                                   name="HRD_PaymentMethod" asp-for="HRD_PaymentMethod"
                                                                   value="Transfer" id="payTransfer"
                                                                   @(Model.HRD_PaymentMethod == "Transfer" ? "checked" : "")
                                                                   style="transform: scale(1.2);">
                                                            <label class="form-check-label fw-medium" for="payTransfer">
                                                                โอนเงิน
                                                            </label>
                                                        </div>
                                                        <div class="form-check">
                                                            <input class="form-check-input" type="radio"
                                                                   name="HRD_PaymentMethod" asp-for="HRD_PaymentMethod"
                                                                   value="Cash" id="payCash"
                                                                   @(Model.HRD_PaymentMethod == "Cash" ? "checked" : "")
                                                                   style="transform: scale(1.2);">
                                                            <label class="form-check-label fw-medium" for="payCash">
                                                                เงินสด
                                                            </label>
                                                        </div>
                                                    </div>
                                                </div>

                                                <!-- ลงชื่อผู้บันทึก -->
                                                <div class="col-md-12">
                                                    <label asp-for="HRD_RecorderSignature" class="form-label fw-bold">
                                                        ✍️ ลงชื่อ : ผู้บันทึก
                                                    </label>
                                                    <input asp-for="HRD_RecorderSignature" name="HRD_RecorderSignature" type="text" class="form-control form-control-lg"
                                                           value="@Model.HRD_RecorderSignature" placeholder="ระบุชื่อผู้บันทึก" style="border-radius: 8px;" />
                                                </div>

                                                <!-- ==================== HRD Section 4: การดำเนินงานหลังอนุมัติ ==================== -->
                                                <div class="col-md-12 mt-3">
                                                    <div class="border rounded p-3" style="background-color: #f8f9fa;">
                                                        <label class="form-label fw-bold mb-3">📋 การดำเนินงานหลังอนุมัติ</label>
                                                        <div class="row g-3">
                                                            <!-- บันทึกประวัติฝึกอบรม Training Record -->
                                                            <div class="col-md-4">
                                                                <div class="form-check">
                                                                    <input class="form-check-input" type="checkbox"
                                                                           name="HRD_TrainingRecord" asp-for="HRD_TrainingRecord"
                                                                           value="true" id="hrdTrainingRecord"
                                                                           @(Model.HRD_TrainingRecord == true ? "checked" : "")
                                                                           style="transform: scale(1.3);">
                                                                    <label class="form-check-label fw-medium ms-1" for="hrdTrainingRecord">
                                                                        บันทึกประวัติฝึกอบรม Training Record
                                                                    </label>
                                                                </div>
                                                            </div>
                                                            <!-- การจัดการความรู้ (KM) -->
                                                            <div class="col-md-4">
                                                                <div class="form-check">
                                                                    <input class="form-check-input" type="checkbox"
                                                                           name="HRD_KnowledgeManagementDone" asp-for="HRD_KnowledgeManagementDone"
                                                                           value="true" id="hrdKMDone"
                                                                           @(Model.HRD_KnowledgeManagementDone == true ? "checked" : "")
                                                                           style="transform: scale(1.3);">
                                                                    <label class="form-check-label fw-medium ms-1" for="hrdKMDone">
                                                                        การจัดการความรู้ (KM)
                                                                    </label>
                                                                </div>
                                                            </div>
                                                            <!-- การยื่นขอรับรองหลักสูตร -->
                                                            <div class="col-md-4">
                                                                <div class="form-check">
                                                                    <input class="form-check-input" type="checkbox"
                                                                           name="HRD_CourseCertification" asp-for="HRD_CourseCertification"
                                                                           value="true" id="hrdCourseCert"
                                                                           @(Model.HRD_CourseCertification == true ? "checked" : "")
                                                                           style="transform: scale(1.3);">
                                                                    <label class="form-check-label fw-medium ms-1" for="hrdCourseCert">
                                                                        การยื่นขอรับรองหลักสูตร
                                                                    </label>
                                                                </div>
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>

                                    <!-- ==================== Modal: เพิ่มประวัติการอบรม ==================== -->
                                    <div class="modal fade" id="trainingHistoryModal" tabindex="-1" aria-labelledby="trainingHistoryModalLabel" aria-hidden="true">
                                        <div class="modal-dialog modal-dialog-centered">
                                            <div class="modal-content" style="border-radius: 15px;">
                                                <div class="modal-header bg-primary text-white" style="border-radius: 15px 15px 0 0;">
                                                    <h5 class="modal-title" id="trainingHistoryModalLabel">
                                                        <i class="fas fa-plus-circle me-2"></i>เพิ่มประวัติการอบรม
                                                    </h5>
                                                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                                                </div>
                                                <div class="modal-body p-4">
                                                    <div class="mb-3">
                                                        <label class="form-label fw-bold">รหัสพนักงาน</label>
                                                        <!-- Public: dropdown ดึงจากตาราง -->
                                                        <select class="form-select" id="historyEmpCode" style="border-radius: 8px;">
                                                            <option value="">-- เลือกรหัสพนักงาน --</option>
                                                        </select>
                                                        <!-- In House: พิมพ์เอง (manual) -->
                                                        <input type="text" class="form-control" id="historyEmpCodeManual" placeholder="ระบุรหัสพนักงาน" style="border-radius: 8px; display: none;">
                                                    </div>
                                                    <div class="mb-3">
                                                        <label class="form-label fw-bold">ชื่อ - สกุล</label>
                                                        <input type="text" class="form-control" id="historyEmpName" placeholder="ระบุชื่อ - สกุล" style="border-radius: 8px;" readonly>
                                                    </div>
                                                    <div class="mb-3">
                                                        <div class="d-flex justify-content-between align-items-center">
                                                            <label class="form-label fw-bold mb-0">ประวัติการอบรม</label>
                                                            <button type="button" class="btn btn-sm btn-outline-info" id="btnSearchTrainingRecord" title="ค้นหาประวัติการอบรม" style="border-radius: 15px; padding: 2px 10px;">
                                                                <i class="fas fa-search me-1"></i>ค้นหา
                                                            </button>
                                                        </div>
                                                        <div class="d-flex gap-4 mt-2">
                                                            <div class="form-check">
                                                                <input class="form-check-input" type="radio" name="historyType" value="Never" id="historyNever" style="transform: scale(1.2);">
                                                                <label class="form-check-label" for="historyNever">ไม่เคย</label>
                                                            </div>
                                                            <div class="form-check">
                                                                <input class="form-check-input" type="radio" name="historyType" value="Ever" id="historyEver" style="transform: scale(1.2);">
                                                                <label class="form-check-label" for="historyEver">เคย</label>
                                                            </div>
                                                            <div class="form-check">
                                                                <input class="form-check-input" type="radio" name="historyType" value="Similar" id="historySimilar" style="transform: scale(1.2);">
                                                                <label class="form-check-label" for="historySimilar">ใกล้เคียง</label>
                                                            </div>
                                                        </div>
                                                    </div>
                                                    <div class="mb-3">
                                                        <label class="form-label fw-bold">เมื่อวันที่</label>
                                                        <input type="text" class="form-control" id="historyDate" placeholder="dd/mm/yyyy" style="border-radius: 8px;">
                                                    </div>
                                                    <div class="mb-3">
                                                        <label class="form-label fw-bold">ชื่อหลักสูตร</label>
                                                        <input type="text" class="form-control" id="historyCourseName" placeholder="ระบุชื่อหลักสูตร" style="border-radius: 8px;">
                                                    </div>
                                                </div>
                                                <div class="modal-footer">
                                                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal" style="border-radius: 20px;">ยกเลิก</button>
                                                    <button type="button" class="btn btn-primary" id="btnSaveTrainingHistory" style="border-radius: 20px;">
                                                        <i class="fas fa-save me-1"></i> บันทึก
                                                    </button>
                                                </div>
                                            </div>
                                        </div>
                                    </div>

                                    <!-- ==================== Modal: ค้นหาประวัติการอบรมจากระบบ ==================== -->
                                    <div class="modal fade" id="trainingSearchResultModal" tabindex="-1" aria-labelledby="trainingSearchResultModalLabel" aria-hidden="true">
                                        <div class="modal-dialog modal-lg modal-dialog-centered modal-dialog-scrollable">
                                            <div class="modal-content" style="border-radius: 15px;">
                                                <div class="modal-header bg-info text-white" style="border-radius: 15px 15px 0 0;">
                                                    <h5 class="modal-title" id="trainingSearchResultModalLabel">
                                                        <i class="fas fa-search me-2"></i>ประวัติการอบรมจากระบบ
                                                    </h5>
                                                    <button type="button" class="btn-close btn-close-white" id="btnCloseSearchResult" aria-label="Close"></button>
                                                </div>
                                                <div class="modal-body p-4">
                                                    <div id="searchResultLoading" class="text-center py-4" style="display: none;">
                                                        <div class="spinner-border text-info" role="status">
                                                            <span class="visually-hidden">Loading...</span>
                                                        </div>
                                                        <p class="mt-2 text-muted">กำลังค้นหาข้อมูล...</p>
                                                    </div>
                                                    <div id="searchResultEmpty" class="text-center py-4" style="display: none;">
                                                        <i class="fas fa-info-circle text-muted" style="font-size: 2rem;"></i>
                                                        <p class="mt-2 text-muted">ไม่พบประวัติการอบรมของพนักงานคนนี้</p>
                                                    </div>
                                                    <div class="table-responsive" id="searchResultTableContainer" style="display: none;">
                                                        <p class="text-muted mb-2"><small>คลิกเลือกแถวเพื่อนำข้อมูลไปใส่ในฟอร์ม</small></p>
                                                        <table class="table table-bordered table-hover mb-0" style="font-size: 0.9rem;">
                                                            <thead class="table-info">
                                                                <tr>
                                                                    <th class="text-center" style="min-width: 100px;">รหัสพนักงาน</th>
                                                                    <th class="text-center" style="min-width: 150px;">ชื่อ - สกุล</th>
                                                                    <th class="text-center" style="min-width: 200px;">ชื่อหลักสูตร</th>
                                                                    <th class="text-center" style="min-width: 120px;">อบรมเมื่อวันที่</th>
                                                                </tr>
                                                            </thead>
                                                            <tbody id="searchResultTableBody">
                                                            </tbody>
                                                        </table>
                                                    </div>
                                                </div>
                                                <div class="modal-footer">
                                                    <button type="button" class="btn btn-secondary" id="btnCancelSearchResult" style="border-radius: 20px;">ยกเลิก</button>
                                                </div>
                                            </div>
                                        </div>
                                    </div>

                                    <script>
                                        document.addEventListener('DOMContentLoaded', function () {

                                            // ===== ✅ Flatpickr สำหรับ HRD dates (init FIRST เพื่อป้องกัน error จาก code อื่นบล็อก) =====
                                            try {
                                                var hrdContactEl = document.getElementById('HRD_ContactDate');
                                                if (hrdContactEl) {
                                                    var fpHrdContact = flatpickr(hrdContactEl, {
                                                        dateFormat: "Y-m-d",
                                                        altInput: true,
                                                        altFormat: "d/m/Y",
                                                        allowInput: false,
                                                        clickOpens: true,
                                                        appendTo: document.body,
                                                        altInputClass: "form-control form-control-lg flatpickr-alt-input",
                                                        onReady: function() { console.log('✅ Flatpickr READY: HRD_ContactDate'); }
                                                    });
                                                    // ✅ Force re-enable: HRD section จะแสดงเฉพาะ user ที่มีสิทธิ์ (canEditHRDSection=true)
                                                    // ดังนั้นต้องเปิดให้แก้ไขได้เสมอ ไม่ว่า canEdit จะเป็น true/false
                                                    hrdContactEl.disabled = false;
                                                    if (fpHrdContact.altInput) {
                                                        fpHrdContact.altInput.disabled = false;
                                                        fpHrdContact.altInput.style.cursor = 'pointer';
                                                    }
                                                    console.log('✅ Flatpickr initialized: HRD_ContactDate');
                                                } else {
                                                    console.warn('⚠️ Element not found: HRD_ContactDate');
                                                }

                                                var hrdPaymentEl = document.getElementById('HRD_PaymentDate');
                                                if (hrdPaymentEl) {
                                                    var fpHrdPayment = flatpickr(hrdPaymentEl, {
                                                        dateFormat: "Y-m-d",
                                                        altInput: true,
                                                        altFormat: "d/m/Y",
                                                        allowInput: false,
                                                        clickOpens: true,
                                                        appendTo: document.body,
                                                        altInputClass: "form-control form-control-lg flatpickr-alt-input",
                                                        onReady: function() { console.log('✅ Flatpickr READY: HRD_PaymentDate'); }
                                                    });
                                                    hrdPaymentEl.disabled = false;
                                                    if (fpHrdPayment.altInput) {
                                                        fpHrdPayment.altInput.disabled = false;
                                                        fpHrdPayment.altInput.style.cursor = 'pointer';
                                                    }
                                                    console.log('✅ Flatpickr initialized: HRD_PaymentDate');
                                                } else {
                                                    console.warn('⚠️ Element not found: HRD_PaymentDate');
                                                }

                                                var historyDateEl = document.getElementById('historyDate');
                                                if (historyDateEl) {
                                                    flatpickr(historyDateEl, {
                                                        dateFormat: "Y-m-d",
                                                        altInput: true,
                                                        altFormat: "d/m/Y",
                                                        allowInput: false,
                                                        clickOpens: true,
                                                        appendTo: document.body,
                                                        altInputClass: "form-control flatpickr-alt-input"
                                                    });
                                                    console.log('✅ Flatpickr initialized: historyDate');
                                                }
                                            } catch (e) {
                                                console.error('❌ Flatpickr init error (HRD/History):', e);
                                            }

                                            // ===== Membership Radio Toggle =====
                                            try {
                                            document.querySelectorAll('input[name="HRD_MembershipType"]').forEach(function (radio) {
                                                radio.addEventListener('change', function () {
                                                    var memberCost = document.getElementById('memberCost');
                                                    var nonMemberCost = document.getElementById('nonMemberCost');

                                                    if (this.value === 'Member') {
                                                        memberCost.disabled = false;
                                                        nonMemberCost.disabled = true;
                                                        nonMemberCost.value = '';
                                                    } else {
                                                        memberCost.disabled = true;
                                                        memberCost.value = '';
                                                        nonMemberCost.disabled = false;
                                                    }
                                                });
                                            });

                                            // Sync membership cost to hidden field
                                            function syncMembershipCost() {
                                                var memberType = document.querySelector('input[name="HRD_MembershipType"]:checked');
                                                var hiddenField = document.getElementById('hrdMembershipCostHidden');
                                                if (memberType) {
                                                    var costField = memberType.value === 'Member'
                                                        ? document.getElementById('memberCost')
                                                        : document.getElementById('nonMemberCost');
                                                    hiddenField.value = costField.value || '';
                                                }
                                            }
                                            document.getElementById('memberCost').addEventListener('input', syncMembershipCost);
                                            document.getElementById('nonMemberCost').addEventListener('input', syncMembershipCost);

                                            // ===== Auto-fill ยอดเงินคงเหลือจากตารางพนักงาน =====
                                            // ✅ ปรับ Logic: TYP = แก้ไขได้ / Department = readonly + auto-fill
                                            function updateDeptBudgetRemaining() {
                                                var field = document.getElementById('hrdDeptBudgetRemaining');
                                                var budgetUsage = document.querySelector('input[name="HRD_BudgetUsage"]:checked');

                                                // auto-fill จากตาราง (ทั้ง TYP และ Department)
                                                var rows = document.querySelectorAll('#employeeTableBody tr');
                                                var lastRemainingCost = 0;
                                                if (rows.length > 0) {
                                                    var lastRow = rows[rows.length - 1];
                                                    var remainingCostCell = lastRow.querySelector('.remaining-cost');
                                                    if (remainingCostCell) {
                                                        // ใช้ data-value ก่อน ถ้าไม่มีค่อยใช้ textContent
                                                        var val = remainingCostCell.dataset.value || remainingCostCell.textContent.replace(/,/g, '').trim();
                                                        lastRemainingCost = parseFloat(val) || 0;
                                                    }
                                                }
                                                if (field) {
                                                    field.value = lastRemainingCost.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
                                                }
                                                console.log('✅ Updated hrdDeptBudgetRemaining:', lastRemainingCost);
                                            }

                                            // ✅ Toggle readonly สำหรับ HRD_DepartmentBudgetRemaining ตาม HRD_BudgetUsage
                                            function toggleBudgetRemainingReadonly() {
                                                var field = document.getElementById('hrdDeptBudgetRemaining');
                                                var budgetUsage = document.querySelector('input[name="HRD_BudgetUsage"]:checked');

                                                if (!field) return;

                                                if (budgetUsage && budgetUsage.value === 'TYP') {
                                                    field.removeAttribute('readonly');
                                                    console.log('📊 Budget Usage: TYP - Field is editable + auto-fill');
                                                } else {
                                                    field.setAttribute('readonly', 'readonly');
                                                    console.log('📊 Budget Usage: Department - Field is readonly + auto-fill');
                                                }
                                                // auto-fill ค่าจากตารางทุกกรณี (TYP และ Department)
                                                updateDeptBudgetRemaining();
                                            }

                                            // ✅ Event listener สำหรับ radio button HRD_BudgetUsage
                                            document.querySelectorAll('input[name="HRD_BudgetUsage"]').forEach(function(radio) {
                                                radio.addEventListener('change', toggleBudgetRemainingReadonly);
                                            });

                                            // Observe changes to employee table
                                            var empTableBody = document.getElementById('employeeTableBody');
                                            if (empTableBody) {
                                                var observer = new MutationObserver(updateDeptBudgetRemaining);
                                                observer.observe(empTableBody, { childList: true, subtree: true, characterData: true });
                                                updateDeptBudgetRemaining(); // Initial
                                            }

                                            // ✅ Initial state check เมื่อโหลดหน้า
                                            toggleBudgetRemainingReadonly();
                                            } catch (e) {
                                                console.error('⚠️ HRD membership/budget init error:', e);
                                            }

                                            // ===== Training History Table Management =====
                                            var trainingHistories = [];

                                            // Load existing histories from table
                                            document.querySelectorAll('#trainingHistoryTableBody tr').forEach(function (row) {
                                                var cells = row.querySelectorAll('td');
                                                if (cells.length >= 8) {
                                                    var historyType = 'Never';
                                                    if (cells[4].querySelector('input:checked')) historyType = 'Ever';
                                                    else if (cells[5].querySelector('input:checked')) historyType = 'Similar';
                                                    else if (cells[3].querySelector('input:checked')) historyType = 'Never';

                                                    trainingHistories.push({
                                                        employeeCode: cells[1].textContent.trim(),
                                                        employeeName: cells[2].textContent.trim(),
                                                        historyType: historyType,
                                                        trainingDate: cells[6].textContent.trim(),
                                                        courseName: cells[7].textContent.trim()
                                                    });
                                                }
                                            });

                                            // ✅ Helper: ตรวจว่าตอนนี้เป็นโหมด In House หรือไม่
                                            function isInHouseMode() {
                                                var trainingType = document.querySelector('input[name="TrainingType"]:checked');
                                                return trainingType && trainingType.value === 'In House';
                                            }

                                            // Save Training History
                                            document.getElementById('btnSaveTrainingHistory').addEventListener('click', function () {
                                                // ✅ อ่านรหัสพนักงานจาก element ที่กำลังแสดง (In House = manual, Public = select)
                                                var empCode = isInHouseMode()
                                                    ? document.getElementById('historyEmpCodeManual').value.trim()
                                                    : document.getElementById('historyEmpCode').value.trim();
                                                var empName = document.getElementById('historyEmpName').value.trim();
                                                var historyType = document.querySelector('input[name="historyType"]:checked');
                                                var trainingDate = document.getElementById('historyDate').value;
                                                var courseName = document.getElementById('historyCourseName').value.trim();

                                                if (!empCode || !empName) {
                                                    alert('กรุณาระบุรหัสพนักงานและชื่อ-สกุล');
                                                    return;
                                                }
                                                if (!historyType) {
                                                    alert('กรุณาเลือกประวัติการอบรม (ไม่เคย/เคย/ใกล้เคียง)');
                                                    return;
                                                }

                                                var entry = {
                                                    employeeCode: empCode,
                                                    employeeName: empName,
                                                    historyType: historyType.value,
                                                    trainingDate: trainingDate,
                                                    courseName: courseName
                                                };

                                                trainingHistories.push(entry);
                                                renderTrainingHistoryTable();
                                                updateTrainingHistoryJson();

                                                // Clear modal (ล้างทั้ง select และ manual input)
                                                document.getElementById('historyEmpCode').value = '';
                                                document.getElementById('historyEmpCodeManual').value = '';
                                                document.getElementById('historyEmpName').value = '';
                                                document.querySelectorAll('input[name="historyType"]').forEach(r => r.checked = false);
                                                var historyDateEl = document.getElementById('historyDate');
                                                if (historyDateEl._flatpickr) historyDateEl._flatpickr.clear();
                                                document.getElementById('historyCourseName').value = '';

                                                // Close modal
                                                var modal = bootstrap.Modal.getInstance(document.getElementById('trainingHistoryModal'));
                                                modal.hide();
                                            });

                                            // Render Table
                                            function renderTrainingHistoryTable() {
                                                var tbody = document.getElementById('trainingHistoryTableBody');
                                                tbody.innerHTML = '';

                                                trainingHistories.forEach(function (item, index) {
                                                    var dateDisplay = '';
                                                    if (item.trainingDate) {
                                                        var parts = item.trainingDate.split('-');
                                                        if (parts.length === 3) {
                                                            dateDisplay = parts[2] + '/' + parts[1] + '/' + parts[0];
                                                        } else {
                                                            dateDisplay = item.trainingDate;
                                                        }
                                                    }

                                                    var row = document.createElement('tr');
                                                    row.innerHTML = `
                                                        <td class="text-center align-middle">${index + 1}</td>
                                                        <td class="text-center align-middle">${item.employeeCode}</td>
                                                        <td class="align-middle">${item.employeeName}</td>
                                                        <td class="text-center align-middle"><input type="checkbox" class="form-check-input" disabled ${item.historyType === 'Never' ? 'checked' : ''}></td>
                                                        <td class="text-center align-middle"><input type="checkbox" class="form-check-input" disabled ${item.historyType === 'Ever' ? 'checked' : ''}></td>
                                                        <td class="text-center align-middle"><input type="checkbox" class="form-check-input" disabled ${item.historyType === 'Similar' ? 'checked' : ''}></td>
                                                        <td class="text-center align-middle">${dateDisplay}</td>
                                                        <td class="align-middle">${item.courseName || ''}</td>
                                                        <td class="text-center align-middle">
                                                            <button type="button" class="btn btn-sm btn-outline-danger btn-remove-history" data-index="${index}" title="ลบ">
                                                                <i class="fas fa-trash"></i>
                                                            </button>
                                                        </td>
                                                    `;
                                                    tbody.appendChild(row);
                                                });

                                                // Bind delete buttons
                                                tbody.querySelectorAll('.btn-remove-history').forEach(function (btn) {
                                                    btn.addEventListener('click', function () {
                                                        var idx = parseInt(this.getAttribute('data-index'));
                                                        trainingHistories.splice(idx, 1);
                                                        renderTrainingHistoryTable();
                                                        updateTrainingHistoryJson();
                                                    });
                                                });
                                            }

                                            // Update hidden JSON field
                                            function updateTrainingHistoryJson() {
                                                document.getElementById('trainingHistoryJson').value = JSON.stringify(trainingHistories);
                                            }

                                            // Bind initial delete buttons
                                            document.querySelectorAll('#trainingHistoryTableBody .btn-remove-history').forEach(function (btn) {
                                                btn.addEventListener('click', function () {
                                                    var row = this.closest('tr');
                                                    var rowIndex = Array.from(row.parentNode.children).indexOf(row);
                                                    trainingHistories.splice(rowIndex, 1);
                                                    renderTrainingHistoryTable();
                                                    updateTrainingHistoryJson();
                                                });
                                            });

                                            // Initial JSON
                                            updateTrainingHistoryJson();

                                            // ===== ✅ Populate dropdown รหัสพนักงานจากตารางประวัติการขออบรมฯ =====
                                            function populateHistoryEmpCodeDropdown() {
                                                var select = document.getElementById('historyEmpCode');
                                                if (!select) return;

                                                // เก็บค่าที่เลือกอยู่ (ถ้ามี)
                                                var currentVal = select.value;

                                                // ล้าง options เดิม (เหลือแค่ตัวว่าง)
                                                select.innerHTML = '<option value="">-- เลือกรหัสพนักงาน --</option>';

                                                // ดึงจาก employeeManager.employees[] (ตารางประวัติการขออบรมฯ)
                                                if (typeof employeeManager !== 'undefined' && employeeManager.employees && employeeManager.employees.length > 0) {
                                                    var addedCodes = {};
                                                    employeeManager.employees.forEach(function(emp) {
                                                        if (emp.empCode && !addedCodes[emp.empCode]) {
                                                            addedCodes[emp.empCode] = true;
                                                            var fullName = (emp.prefix || '') + (emp.name || '') + ' ' + (emp.lastname || '');
                                                            fullName = fullName.trim();
                                                            var opt = document.createElement('option');
                                                            opt.value = emp.empCode;
                                                            opt.textContent = emp.empCode;
                                                            opt.dataset.fullname = fullName;
                                                            select.appendChild(opt);
                                                        }
                                                    });
                                                }

                                                // คืนค่าที่เลือกไว้ (ถ้ายังมี)
                                                if (currentVal) {
                                                    select.value = currentVal;
                                                }
                                            }

                                            // ✅ Populate dropdown + สลับโหมด Public/In House เมื่อ Modal เปิด
                                            var trainingHistoryModalEl = document.getElementById('trainingHistoryModal');
                                            if (trainingHistoryModalEl) {
                                                trainingHistoryModalEl.addEventListener('show.bs.modal', function () {
                                                    var trainingType = document.querySelector('input[name="TrainingType"]:checked');
                                                    var isInHouse = trainingType && trainingType.value === 'In House';

                                                    var selectEl = document.getElementById('historyEmpCode');
                                                    var manualEl = document.getElementById('historyEmpCodeManual');
                                                    var nameField = document.getElementById('historyEmpName');
                                                    var searchBtn = document.getElementById('btnSearchTrainingRecord');

                                                    if (isInHouse) {
                                                        // In House → manual: พิมพ์รหัสเอง, พิมพ์ชื่อเอง, ซ่อนปุ่มค้นหา
                                                        selectEl.style.display = 'none';
                                                        manualEl.style.display = '';
                                                        nameField.removeAttribute('readonly');
                                                        searchBtn.style.display = 'none';
                                                    } else {
                                                        // Public → dropdown จากตาราง, ชื่อ readonly, แสดงปุ่มค้นหา
                                                        selectEl.style.display = '';
                                                        manualEl.style.display = 'none';
                                                        nameField.setAttribute('readonly', 'readonly');
                                                        searchBtn.style.display = '';
                                                        populateHistoryEmpCodeDropdown();
                                                    }
                                                });
                                            }

                                            // ✅ เมื่อเลือกรหัสพนักงาน → auto-fill ชื่อ-สกุล
                                            document.getElementById('historyEmpCode').addEventListener('change', function () {
                                                var selectedOption = this.options[this.selectedIndex];
                                                var nameField = document.getElementById('historyEmpName');
                                                if (this.value && selectedOption && selectedOption.dataset.fullname) {
                                                    nameField.value = selectedOption.dataset.fullname;
                                                } else {
                                                    nameField.value = '';
                                                }
                                            });

                                            // ===== ✅ ปุ่มค้นหาประวัติการอบรมจากระบบ =====
                                            document.getElementById('btnSearchTrainingRecord').addEventListener('click', function () {
                                                var empCode = document.getElementById('historyEmpCode').value.trim();
                                                if (!empCode) {
                                                    alert('กรุณาเลือกรหัสพนักงานก่อน');
                                                    return;
                                                }

                                                // แสดง Modal ค้นหา
                                                var searchModal = new bootstrap.Modal(document.getElementById('trainingSearchResultModal'));
                                                searchModal.show();

                                                // แสดง loading
                                                document.getElementById('searchResultLoading').style.display = 'block';
                                                document.getElementById('searchResultEmpty').style.display = 'none';
                                                document.getElementById('searchResultTableContainer').style.display = 'none';
                                                document.getElementById('searchResultTableBody').innerHTML = '';

                                                // Fetch API
                                                fetch('/TrainingRequest/GetEmployeeTrainingHistory?userId=' + encodeURIComponent(empCode))
                                                    .then(function (response) { return response.json(); })
                                                    .then(function (result) {
                                                        document.getElementById('searchResultLoading').style.display = 'none';

                                                        if (result.success && result.data && result.data.length > 0) {
                                                            document.getElementById('searchResultTableContainer').style.display = 'block';
                                                            var tbody = document.getElementById('searchResultTableBody');
                                                            tbody.innerHTML = '';

                                                            result.data.forEach(function (item) {
                                                                // แปลง date เป็น dd/mm/yyyy สำหรับแสดง
                                                                var dateDisplay = '';
                                                                if (item.openDate) {
                                                                    var parts = item.openDate.split('-');
                                                                    if (parts.length === 3) {
                                                                        dateDisplay = parts[2] + '/' + parts[1] + '/' + parts[0];
                                                                    }
                                                                }

                                                                var row = document.createElement('tr');
                                                                row.style.cursor = 'pointer';
                                                                row.dataset.courseName = item.courseName || '';
                                                                row.dataset.openDate = item.openDate || '';
                                                                row.innerHTML =
                                                                    '<td class="text-center align-middle">' + (item.userId || '') + '</td>' +
                                                                    '<td class="align-middle">' + (item.fullName || '') + '</td>' +
                                                                    '<td class="align-middle">' + (item.courseName || '') + '</td>' +
                                                                    '<td class="text-center align-middle">' + dateDisplay + '</td>';

                                                                // ✅ คลิกเลือกแถว → auto-fill ข้อมูลลงใน Modal เดิม
                                                                row.addEventListener('click', function () {
                                                                    var courseName = this.dataset.courseName;
                                                                    var openDate = this.dataset.openDate;

                                                                    // ใส่ชื่อหลักสูตร
                                                                    document.getElementById('historyCourseName').value = courseName;

                                                                    // ใส่วันที่ (ผ่าน flatpickr ถ้ามี, ไม่งั้นใส่ตรง)
                                                                    var historyDateEl = document.getElementById('historyDate');
                                                                    if (historyDateEl._flatpickr && openDate) {
                                                                        historyDateEl._flatpickr.setDate(openDate, true);
                                                                    } else if (openDate) {
                                                                        historyDateEl.value = openDate;
                                                                    }

                                                                    // ปิด Modal ค้นหา
                                                                    var searchModalInstance = bootstrap.Modal.getInstance(document.getElementById('trainingSearchResultModal'));
                                                                    if (searchModalInstance) searchModalInstance.hide();
                                                                });

                                                                tbody.appendChild(row);
                                                            });
                                                        } else {
                                                            document.getElementById('searchResultEmpty').style.display = 'block';
                                                        }
                                                    })
                                                    .catch(function (error) {
                                                        document.getElementById('searchResultLoading').style.display = 'none';
                                                        document.getElementById('searchResultEmpty').style.display = 'block';
                                                        console.error('❌ Error fetching training history:', error);
                                                    });
                                            });

                                            // ✅ ปุ่มปิด/ยกเลิก Modal ค้นหาประวัติ
                                            document.getElementById('btnCloseSearchResult').addEventListener('click', function () {
                                                var searchModalInstance = bootstrap.Modal.getInstance(document.getElementById('trainingSearchResultModal'));
                                                if (searchModalInstance) searchModalInstance.hide();
                                            });
                                            document.getElementById('btnCancelSearchResult').addEventListener('click', function () {
                                                var searchModalInstance = bootstrap.Modal.getInstance(document.getElementById('trainingSearchResultModal'));
                                                if (searchModalInstance) searchModalInstance.hide();
                                            });

                                            // Sync before form submit
                                            var form = document.querySelector('form');
                                            if (form) {
                                                form.addEventListener('submit', function () {
                                                    updateTrainingHistoryJson();
                                                    syncMembershipCost();
                                                });
                                            }
                                        });
                                    </script>
                                }

                                <!-- ✅ ปุ่มแบบ Multi-Mode -->
                                <div class="text-center mt-5">
                                    @if (isApproveMode)
                                    {
                                        <!-- Approve Mode: แสดงปุ่ม Approve / Revise / Reject + Comment -->
