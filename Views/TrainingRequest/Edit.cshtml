    // ✅ Format แสดงผลในรายการ Dropdown
    function formatEmailOption(option) {
        if (!option.id) {
            return option.text;
        }

        var $option = $(
            '<div>' +
                '<strong>' + option.text + '</strong>' +
                '<br><small class="text-muted">' +
                    (option.name || '') +
                    (option.department ? ' (' + option.department + ')' : '') +
