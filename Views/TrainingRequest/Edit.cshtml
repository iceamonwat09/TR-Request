    // โหลดข้อมูลพนักงานจาก Model.Employees
    async function loadExistingEmployees() {
        const employees = @Html.Raw(Json.Serialize(Model.Employees));

        console.log('🔍 Raw employees data from Model:', employees);

        if (employees && employees.length > 0) {
            console.log(`📊 Loading ${employees.length} existing employees`);

            // ✅ โหลดข้อมูลจาก database โดยตรง (ไม่คำนวณใหม่)
            const trainingType = '@Model.TrainingType';

            // ✅ ตัวแปรเก็บยอดรวมในฟอร์มนี้
            let accumulatedCost = 0;
            let accumulatedHours = 0;

            employees.forEach((emp, index) => {
                console.log(`Employee ${index + 1}:`, emp);
                // แยกชื่อออกเป็น prefix, name, lastname (ถ้าเป็นไปได้)
                const fullName = emp.employeeName || '';  // ← camelCase
                const nameParts = fullName.split(' ');

                let prefix = '';
                let name = '';
                let lastname = '';

                if (nameParts.length === 1) {
                    name = nameParts[0];
                } else if (nameParts.length === 2) {
                    name = nameParts[0];
                    lastname = nameParts[1];
                } else if (nameParts.length >= 3) {
                    prefix = nameParts[0];
                    name = nameParts.slice(1, -1).join(' ');
                    lastname = nameParts[nameParts.length - 1];
                }

                // ✅ อ่านค่าคงเหลือจาก database (ไม่คำนวณ)
                const remainingHours = emp.remainingHours || 0;
                const remainingCost = emp.remainingCost || 0;

                console.log(`Employee ${index + 1} (${emp.employeeCode}): Loaded remaining from DB - Hours: ${remainingHours}, Cost: ${remainingCost}`);

                // สร้าง employee object ตามโครงสร้างที่ EmployeeManager ต้องการ
                const employeeData = {
                    empCode: emp.employeeCode || '',  // ← camelCase
                    prefix: prefix,
                    name: name,
                    lastname: lastname,
                    position: emp.position || '',  // ← camelCase
                    level: emp.level || '',  // ← เพิ่มใหม่
                    department: emp.department || '',  // ← เพิ่มใหม่
                    currentYearHours: emp.previousTrainingHours || 0,  // ← camelCase
                    currentYearCost: emp.previousTrainingCost || 0,  // ← camelCase
                    thisTimeHours: emp.currentTrainingHours || 0,  // ← camelCase
                    thisTimeCost: emp.currentTrainingCost || 0,  // ← camelCase
                    remainingHours: remainingHours,
                    remainingCost: remainingCost,
                    notes: emp.notes || ''  // ← camelCase
                };

                console.log('✅ Employee data created:', employeeData);

                // ✅ รวมยอดสำหรับ PUBLIC training
                if (trainingType?.toUpperCase() === 'PUBLIC') {
                    accumulatedCost += employeeData.thisTimeCost;
                    accumulatedHours += employeeData.thisTimeHours;
                }

                // เพิ่ม employee เข้าไปใน array โดยตรง
                employeeManager.employees.push(employeeData);

                // สร้างและแสดง row ในตาราง
                const row = employeeManager.createEmployeeRow(employeeData, employeeManager.rowCounter);
                document.getElementById('employeeTableBody').appendChild(row);

                // ถ้ามี notes ให้ set ค่าเข้าไปใน input
                if (emp.notes) {
                    setTimeout(() => {
                        const noteInput = document.querySelector(`input.note-input[data-emp-code="${employeeData.empCode}"]`);
                        if (noteInput) {
                            noteInput.value = emp.notes;
                        }
                    }, 100);
                }

                employeeManager.rowCounter++;
            });

            // ✅ อัพเดตยอดสะสมในฟอร์ม
            if (trainingType?.toUpperCase() === 'PUBLIC') {
                employeeManager.totalCostUsedInForm = accumulatedCost;
                employeeManager.totalHoursUsedInForm = accumulatedHours;
            }

            console.log('✅ Employees loaded:', employees.length);
            console.log('✅ Accumulated totals:', {
                totalCost: employeeManager.totalCostUsedInForm,
                totalHours: employeeManager.totalHoursUsedInForm
            });

            // ✅ ดึงโควต้าฝ่ายจาก API (ใช้พนักงานคนแรก)
            await loadDepartmentQuota(employees[0]);

            // ✅ อัปเดต HRD Budget Remaining หลังโหลดพนักงาน
            if (typeof updateDeptBudgetRemaining === 'function') {
                updateDeptBudgetRemaining();
            }
        } else {
            console.log('ℹ️ No existing employees');
        }
    }

    // ✅ ดึงโควต้าฝ่ายจาก API
    async function loadDepartmentQuota(firstEmployee) {
        try {
            const department = '@Html.Raw(Model.Department)';
            const trainingType = '@Model.TrainingType';
            const employeeCode = firstEmployee.employeeCode;

            console.log('🔍 Fetching department quota...');
            console.log('   Employee Code:', employeeCode);
            console.log('   Department:', department);
            console.log('   Training Type:', trainingType);

            const url = `/api/employee/search/${employeeCode}?department=${encodeURIComponent(department)}&trainingType=${encodeURIComponent(trainingType)}`;
            const response = await fetch(url);

            if (response.ok) {
                const data = await response.json();
                if (data.success && data.employee) {
                    employeeManager.departmentQuota = data.employee.departmentQuota || 0;
                    employeeManager.departmentQhours = data.employee.departmentQhours || 0;
                    employeeManager.updateDepartmentQuotaDisplay();

                    console.log('✅ Department quota loaded:', {
                        departmentQuota: employeeManager.departmentQuota,
                        departmentQhours: employeeManager.departmentQhours
                    });
                }
            }
        } catch (error) {
            console.error('❌ Error loading department quota:', error);
        }
    }

    // Set Department และ Position dropdown
    async function setDepartmentAndPosition() {
        const department = '@Html.Raw(Model.Department)';
        const position = '@Html.Raw(Model.Position)';

        if (department) {
            console.log('🔧 Setting Department:', department);

            const departmentSelect = document.getElementById('departmentSelect');
            if (departmentSelect) {
                // ✅ ตรวจสอบว่ามี option หรือไม่
                const departmentOption = Array.from(departmentSelect.options).find(opt => opt.value === department);
                if (!departmentOption) {
                    console.warn('⚠️ Department option not found:', department);
                    return;
                }

                departmentSelect.value = department;
                console.log('✅ Department set:', department);

                // ✅ Trigger change event to load positions
                const changeEvent = new Event('change');
                departmentSelect.dispatchEvent(changeEvent);

                // ✅ รอให้โหลด positions เสร็จ (รอจาก event listener)
                if (position) {
                    // รอ positions โหลดเสร็จด้วย Promise
                    await new Promise(resolve => {
                        let attempts = 0;
                        const checkInterval = setInterval(() => {
                            const positionSelect = document.getElementById('positionSelect');
                            const hasOptions = positionSelect && positionSelect.options.length > 1; // มากกว่า 1 คือมี options แล้ว

                            if (hasOptions || attempts > 20) { // รอสูงสุด 2 วินาที (20 x 100ms)
                                clearInterval(checkInterval);
                                if (hasOptions) {
                                    positionSelect.value = position;
                                    console.log('✅ Position set:', position);
                                } else {
                                    console.warn('⚠️ Positions not loaded in time');
                                }
                                resolve();
                            }
                            attempts++;
                        }, 100);
                    });
                }
            }
        }
    }

    // Set CCEmail dropdown
    async function setCCEmail() {
        const ccEmail = '@Html.Raw(Model.CCEmail)';

        if (ccEmail) {
            console.log('🔧 Setting CCEmail:', ccEmail);

            // ✅ รอให้ Select2 initialize เสร็จก่อน
            await new Promise(resolve => {
                let attempts = 0;
                const checkInterval = setInterval(() => {
                    const $select = $('#ccEmailSelect');
                    const isSelect2Initialized = $select.data('select2') !== undefined;

                    if (isSelect2Initialized || attempts > 30) { // รอสูงสุด 3 วินาที
                        clearInterval(checkInterval);

                        if (isSelect2Initialized) {
                            // แยก email โดยใช้ทั้ง comma และ semicolon
                            const emails = ccEmail.split(/[,;]/).map(e => e.trim()).filter(e => e);
                            console.log('📧 Parsed emails:', emails);

                            if (emails.length > 0) {
                                emails.forEach(email => {
                                    // สร้าง option ถ้ายังไม่มี
                                    if ($select.find(`option[value="${email}"]`).length === 0) {
                                        const newOption = new Option(email, email, true, true);
                                        $select.append(newOption);
                                    }
                                });

                                // Select the emails
                                $select.val(emails).trigger('change');
                                console.log('✅ CCEmail set:', emails);
                            }
                        } else {
                            console.warn('⚠️ CCEmail Select2 not initialized in time');
                        }
                        resolve();
                    }
                    attempts++;
                }, 100);
            });
        }
    }

