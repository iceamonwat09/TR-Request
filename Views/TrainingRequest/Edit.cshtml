                                                                   value="@Model.KM_CreateReportDate?.ToString("yyyy-MM-dd")"
                                                                   placeholder="dd/mm/yyyy"
                                                                   style="max-width: 250px; border-radius: 8px;"
                                                                   @(Model.KM_CreateReport != true ? "disabled" : "")
                                                                   @(!canEdit ? "disabled" : "")>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>

                                            <!-- Checkbox 3: ถ่ายทอดความรู้ + วันที่ -->
                                            <div class="form-check p-3" style="background-color: white; border-radius: 10px; border: 1px solid #dee2e6;">
                                                <div class="d-flex align-items-start">
                                                    <input class="form-check-input km-checkbox" type="checkbox" name="KM_KnowledgeSharing" id="kmKnowledgeSharingEdit" value="true"
                                                           @(Model.KM_KnowledgeSharing == true ? "checked" : "")
                                                           @(!canEdit ? "disabled" : "") style="transform: scale(1.3); margin-top: 4px;">
                                                    <div class="ms-2 flex-grow-1">
                                                        <label class="form-check-label" for="kmKnowledgeSharingEdit">
                                                            ถ่ายทอดความรู้ที่ได้รับจากการอบรม (Knowledge Sharing) โดยจัดบรรยายถ่ายทอดความรู้ภายในหน่วยงาน
                                                        </label>
                                                        <div class="mt-2">
                                                            <label class="form-label text-primary fw-semibold">โปรดระบุวันที่ดำเนินการ:</label>
                                                            <input type="text" class="form-control" name="KM_KnowledgeSharingDate" id="kmKnowledgeSharingDateEdit"
                                                                   value="@Model.KM_KnowledgeSharingDate?.ToString("yyyy-MM-dd")"
                                                                   placeholder="dd/mm/yyyy"
                                                                   style="max-width: 250px; border-radius: 8px;"
                                                                   @(Model.KM_KnowledgeSharing != true ? "disabled" : "")
                                                                   @(!canEdit ? "disabled" : "")>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <script>
                                    document.addEventListener('DOMContentLoaded', function () {
                                        // Show/Hide KM Section based on TrainingType (Edit)
                                        function toggleKMSectionEdit() {
                                            var selectedType = document.querySelector('input[name="TrainingType"]:checked');
                                            var kmSection = document.getElementById('kmSectionEdit');
                                            if (selectedType && selectedType.value === 'Public') {
                                                kmSection.style.display = 'block';
                                            } else {
                                                kmSection.style.display = 'none';
                                            }
                                        }

                                        document.querySelectorAll('input[name="TrainingType"]').forEach(function (radio) {
                                            radio.addEventListener('change', toggleKMSectionEdit);
                                        });

                                        // ✅ Flatpickr สำหรับ KM date fields (Edit)
                                        var kmCreateDateEl = document.getElementById('kmCreateReportDateEdit');
                                        var kmSharingDateEl = document.getElementById('kmKnowledgeSharingDateEdit');
                                        var isKmCreateDisabled = @((Model.KM_CreateReport != true || !canEdit).ToString().ToLower());
                                        var isKmSharingDisabled = @((Model.KM_KnowledgeSharing != true || !canEdit).ToString().ToLower());

                                        if (kmCreateDateEl) {
                                            var fpKmCreateEdit = flatpickr(kmCreateDateEl, {
                                                dateFormat: "Y-m-d",
                                                altInput: true,
                                                altFormat: "d/m/Y",
                                                allowInput: false,
                                                appendTo: document.body,
                                                altInputClass: "form-control flatpickr-alt-input"
                                            });
                                            if (fpKmCreateEdit.altInput) fpKmCreateEdit.altInput.disabled = isKmCreateDisabled;
                                        }

                                        if (kmSharingDateEl) {
                                            var fpKmSharingEdit = flatpickr(kmSharingDateEl, {
                                                dateFormat: "Y-m-d",
                                                altInput: true,
                                                altFormat: "d/m/Y",
                                                allowInput: false,
                                                appendTo: document.body,
                                                altInputClass: "form-control flatpickr-alt-input"
                                            });
                                            if (fpKmSharingEdit.altInput) fpKmSharingEdit.altInput.disabled = isKmSharingDisabled;
                                        }

                                        // Enable/Disable date fields based on checkbox (Edit)
                                        var kmCreateReportEdit = document.getElementById('kmCreateReportEdit');
                                        if (kmCreateReportEdit) {
                                            kmCreateReportEdit.addEventListener('change', function () {
                                                var dateField = document.getElementById('kmCreateReportDateEdit');
                                                dateField.disabled = !this.checked;
                                                if (dateField._flatpickr && dateField._flatpickr.altInput) {
                                                    dateField._flatpickr.altInput.disabled = !this.checked;
                                                }
                                                if (!this.checked && dateField._flatpickr) {
                                                    dateField._flatpickr.clear();
                                                }
                                            });
                                        }

                                        var kmKnowledgeSharingEdit = document.getElementById('kmKnowledgeSharingEdit');
                                        if (kmKnowledgeSharingEdit) {
                                            kmKnowledgeSharingEdit.addEventListener('change', function () {
                                                var dateField = document.getElementById('kmKnowledgeSharingDateEdit');
                                                dateField.disabled = !this.checked;
                                                if (dateField._flatpickr && dateField._flatpickr.altInput) {
                                                    dateField._flatpickr.altInput.disabled = !this.checked;
                                                }
                                                if (!this.checked && dateField._flatpickr) {
                                                    dateField._flatpickr.clear();
                                                }
                                            });
                                        }
                                    });
                                </script>

