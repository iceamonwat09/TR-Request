@model TrainingRequestApp.Models.TrainingRequest
<div class="container-fluid py-4" style="background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%); min-height: 100vh;">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-11">
                <div class="card shadow-lg border-0" style="border-radius: 15px;">
                    <div class="card-header bg-primary text-center py-4" style="border-radius: 15px 15px 0 0;">
                        <h2 class="mb-0 text-white fw-bold">
                            📌 เพิ่มคำร้องขออบรม
                        </h2>
                    </div>

                    <div class="card-body p-4">
                        <form id="trainingRequestForm" method="post" enctype="multipart/form-data">

                            <!-- การเลือกบริษัทและประเภทการอบรม -->
                            <div class="row mb-4">
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label class="form-label fw-bold text-dark mb-3">
                                            🏢 เลือกบริษัท
                                        </label>
                                        <div class="d-flex gap-4">
                                            <div class="form-check">
                                                <input class="form-check-input" type="radio" name="Company" asp-for="Company" value="F2-สมุทรสาคร" id="company1" style="transform: scale(1.2);">
                                                <label class="form-check-label fw-medium" for="company1">
                                                    F2-สมุทรสาคร
                                                </label>
                                            </div>
                                            <div class="form-check">
                                                <input class="form-check-input" type="radio" name="Company" asp-for="Company" value="F4-ปราจีนบุรี" id="company2" style="transform: scale(1.2);">
                                                <label class="form-check-label fw-medium" for="company2">
                                                    F4-ปราจีนบุรี
                                                </label>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label class="form-label fw-bold text-dark mb-3">
                                            📚 ประเภทการอบรม
                                        </label>
                                        <div class="d-flex gap-4">
                                            <div class="form-check">
                                                <input class="form-check-input" type="radio" name="TrainingType" asp-for="TrainingType" value="Public" id="type1" style="transform: scale(1.2);">
                                                <label class="form-check-label fw-medium" for="type1">
                                                    Public
                                                </label>
                                            </div>
                                            <div class="form-check">
                                                <input class="form-check-input" type="radio" name="TrainingType" asp-for="TrainingType" value="In House" id="type2" style="transform: scale(1.2);">
                                                <label class="form-check-label fw-medium" for="type2">
                                                    In House
                                                </label>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- ==================== แหล่งงบประมาณ (เฉพาะ Public) ==================== -->
                            <div class="row mt-3" id="budgetSourceSection" style="display: none;">
                                <div class="col-md-12">
                                    <div class="form-group">
                                        <label class="form-label fw-bold text-dark mb-2">
                                            💰 แหล่งงบประมาณ <span class="text-danger">*</span>
                                        </label>
                                        <div class="d-flex gap-4">
                                            <div class="form-check">
                                                <input class="form-check-input" type="radio" name="BudgetSource" value="TYP" id="budgetSourceTYP" style="transform: scale(1.2);">
                                                <label class="form-check-label fw-medium" for="budgetSourceTYP">
                                                    ใช้งบประมาณตามแผน TYP
                                                </label>
                                            </div>
                                            <div class="form-check">
                                                <input class="form-check-input" type="radio" name="BudgetSource" value="Department" id="budgetSourceDept" style="transform: scale(1.2);">
                                                <label class="form-check-label fw-medium" for="budgetSourceDept">
                                                    ใช้งบต้นสังกัด
                                                </label>
                                            </div>
                                        </div>
                                        <small class="text-muted" id="budgetSourceHelp">กรุณาเลือกแหล่งงบประมาณก่อนเพิ่มพนักงาน</small>
                                    </div>
                                </div>
                            </div>

                            <hr class="my-4">

                            <!-- ส่วนแรก - ข้อมูลหลัก -->
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <!-- ซ่อน Factory -->
                                    <div class="form-group" style="display: none;">
                                        <label asp-for="Factory" class="form-label fw-bold">🏭 โรงงาน</label>
                                        <input asp-for="Factory" name="Factory" id="Factory" class="form-control form-control-lg" style="border-radius: 10px;" />
                                    </div>
                                    <!-- ย้าย SeminarTitle มาตำแหน่งนี้ -->
                                    <div class="form-group">
                                        <label asp-for="SeminarTitle" class="form-label fw-bold">📖 เรื่องสัมมนา</label>
                                        <input asp-for="SeminarTitle" id="SeminarTitle" name="SeminarTitle" class="form-control form-control-lg" style="border-radius: 10px;" />
                                    </div>
                                    <div class="form-group">
                                        <label class="form-label fw-bold">
                                            📧 CC.Mail
                                            <small class="text-muted">(เลือกได้หลายอีเมล)</small>
                                        </label>
                                        <select id="ccEmailSelect"
                                                class="form-select form-select-lg"
                                                multiple
                                                style="width: 100%; border-radius: 10px;">
                                            <!-- Options จะโหลดจาก JavaScript -->
                                        </select>
                                        <!-- Hidden inputs จะถูกสร้างที่นี่ -->
                                        <div id="ccEmailHiddenInputs"></div>
                                        <span class="text-danger" asp-validation-for="CCEmail"></span>
                                    </div>
                                    <div class="form-group">
                                        <label asp-for="Department" class="form-label fw-bold">🏢 ฝ่าย</label>
                                        <select asp-for="Department" id="departmentSelect" name="Department" class="form-select form-select-lg" style="border-radius: 10px;" required>
                                            <option value="">-- เลือกฝ่าย --</option>
                                        </select>
                                        <span class="text-danger" asp-validation-for="Department"></span>
                                    </div>

                                    <!-- ✅ เพิ่ม Position Dropdown ใหม่ -->
                                    <div class="form-group">
                                        <label class="form-label fw-bold">👔 แผนก</label>
                                        <select id="positionSelect" name="Position" class="form-select form-select-lg" style="border-radius: 10px;" disabled>
                                            <option value="">-- เลือกฝ่ายก่อน --</option>
                                        </select>
                                    </div>

                                    <!-- ✅ เพิ่มช่อง การเดินทาง (ซ่อนไว้ - ไม่ได้ใช้งานแล้ว) -->
                                    <div class="form-group" style="display: none;">
                                        <label class="form-label fw-bold">🚗 การเดินทาง</label>
                                        <div class="d-flex gap-4 mt-2">
                                            <div class="form-check">
                                                <input class="form-check-input" type="radio" name="TravelMethod" id="travelMethod1" value="จัดรถรับส่ง" style="transform: scale(1.2);">
                                                <label class="form-check-label fw-medium" for="travelMethod1">
                                                    จัดรถรับส่ง
                                                </label>
                                            </div>
                                            <div class="form-check">
                                                <input class="form-check-input" type="radio" name="TravelMethod" id="travelMethod2" value="เดินทางเอง" style="transform: scale(1.2);">
                                                <label class="form-check-label fw-medium" for="travelMethod2">
                                                    เดินทางเอง
                                                </label>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="col-md-6">
                                    <div class="row">
                                        <div class="col-md-6">
                                            <div class="form-group">
                                                <label asp-for="StartDate" class="form-label fw-bold">📅 วันที่เริ่มอบรม</label>
                                                <input asp-for="StartDate" id="StartDate" name="StartDate" class="form-control form-control-lg" type="text" placeholder="dd/mm/yyyy" style="border-radius: 10px;" />
                                            </div>
                                        </div>
                                        <div class="col-md-6">
                                            <div class="form-group">
                                                <label asp-for="EndDate" class="form-label fw-bold">📅 วันที่สิ้นสุดการอบรม</label>
                                                <input asp-for="EndDate" id="EndDate" name="EndDate" class="form-control form-control-lg" type="text" placeholder="dd/mm/yyyy" style="border-radius: 10px;" />
                                            </div>
                                        </div>
                                    </div>

                                    <div class="form-group">
                                        <label asp-for="TrainingLocation" class="form-label fw-bold">📍 สถานที่อบรม</label>
                                        <input asp-for="TrainingLocation" id="TrainingLocation" name="TrainingLocation" class="form-control form-control-lg" style="border-radius: 10px;" />
                                    </div>

                                    <div class="form-group">
                                        <label asp-for="Instructor" class="form-label fw-bold">👨‍🏫 วิทยากร/สถาบัน</label>
                                        <input asp-for="Instructor" id="Instructor" name="Instructor" class="form-control form-control-lg" style="border-radius: 10px;" />
                                    </div>

                                    <!-- ✅ เพิ่มช่อง กลุ่มเป้าหมาย -->
                                    <div class="form-group">
                                        <label class="form-label fw-bold">🎯 กลุ่มเป้าหมาย</label>
                                        <input type="text" name="TargetGroup" id="TargetGroup" class="form-control form-control-lg" placeholder="ระบุกลุ่มเป้าหมาย..." style="border-radius: 10px;" />
                                    </div>
                                </div>

                                <!-- 💰 รายละเอียดงบประมาณ (Public) - 2 ช่อง -->
                                <div class="col-12 mt-4" id="budgetPublicCard" style="display: none;">
                                    <div class="card border-0 shadow-sm" style="border-radius: 12px;">
                                        <div class="card-header bg-info text-white" style="border-radius: 12px 12px 0 0;">
                                            <h5 class="mb-0 fw-bold">💰 รายละเอียดงบประมาณ (Public)</h5>
                                        </div>
                                        <div class="card-body p-4">
                                            <div class="row g-3">
                                                <!-- ค่าใช้จ่ายต่อคน -->
                                                <div class="col-md-6">
                                                    <label class="form-label fw-bold">💰 ค่าใช้จ่ายต่อคน (บาท)</label>
                                                    <input type="number" id="CostPerPerson" name="CostPerPerson" class="form-control form-control-lg budget-input-public" step="0.01" min="0" value="0" style="border-radius: 10px;" />
                                                </div>

                                                <!-- จำนวนชั่วโมงการอบรม -->
                                                <div class="col-md-6">
                                                    <label class="form-label fw-bold">⏰ จำนวนชั่วโมงการอบรม</label>
                                                    <input type="number" name="TrainingHours" id="TrainingHours" class="form-control form-control-lg budget-input-public" min="0.5" step="0.5" value="0" style="border-radius: 10px;" />
                                                </div>

                                                <!-- รวมสุทธิ -->
                                                <div class="col-12">
                                                    <hr class="my-3">
                                                    <div class="alert alert-success d-flex justify-content-between align-items-center" style="border-radius: 10px;">
                                                        <span class="fw-bold fs-5">💵 รวมสุทธิ (บาท):</span>
                                                        <span class="fw-bold fs-4 text-success" id="totalCostDisplayPublic">0.00</span>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <!-- 💰 รายละเอียดงบประมาณ (In House) - 7 ช่อง -->
                                <div class="col-12 mt-4" id="budgetInHouseCard" style="display: none;">
                                    <div class="card border-0 shadow-sm" style="border-radius: 12px;">
                                        <div class="card-header bg-warning text-dark" style="border-radius: 12px 12px 0 0;">
                                            <h5 class="mb-0 fw-bold">💰 รายละเอียดงบประมาณ (In House)</h5>
                                        </div>
                                        <div class="card-body p-4">
                                            <div class="row g-3">


                                                <!-- ค่าลงทะเบียน/วิทยากร -->
                                                <div class="col-md-6">
                                                    <label asp-for="RegistrationCost" class="form-label fw-bold">📋 ค่าลงทะเบียน/วิทยากร (บาท)</label>
                                                    <input asp-for="RegistrationCost" name="RegistrationCost" id="RegistrationCost" class="form-control form-control-lg budget-input" type="number" step="0.01" min="0" value="0" style="border-radius: 10px;" />
                                                </div>


                                                <!-- ค่าวิทยากร -->
                                                <div class="col-md-6">
                                                    <label asp-for="InstructorFee" class="form-label fw-bold">👨‍🏫 ค่าวิทยากร (บาท)</label>
                                                    <input asp-for="InstructorFee" name="InstructorFee" id="InstructorFee" class="form-control form-control-lg budget-input-inhouse" type="number" step="0.01" min="0" value="0" style="border-radius: 10px;" />
                                                </div>

                                                <!-- ค่าคอมแมนวิทยากร -->
                                                <div class="col-md-6" style="display: none;">
                                                    <label class="form-label fw-bold">💼 ค่าคอมแมนวิทยากร (บาท)</label>
                                                    <input name="InstructorCommission" id="InstructorCommission" class="form-control form-control-lg budget-input-inhouse" type="number" step="0.01" min="0" value="0" style="border-radius: 10px;" />
                                                </div>

                                                <!-- ค่าอุปกรณ์ -->
                                                <div class="col-md-6">
                                                    <label asp-for="EquipmentCost" class="form-label fw-bold">🛠️ ค่าอุปกรณ์ (บาท)</label>
                                                    <input asp-for="EquipmentCost" name="EquipmentCost" id="EquipmentCost" class="form-control form-control-lg budget-input-inhouse" type="number" step="0.01" min="0" value="0" style="border-radius: 10px;" />
                                                </div>

                                                <!-- ค่าอาหาร -->
                                                <div class="col-md-6">
                                                    <label asp-for="FoodCost" class="form-label fw-bold">🍽️ ค่าอาหาร (บาท)</label>
                                                    <input asp-for="FoodCost" name="FoodCost" id="FoodCost" class="form-control form-control-lg budget-input-inhouse" type="number" step="0.01" min="0" value="0" style="border-radius: 10px;" />
                                                </div>

                                                <!-- อื่นๆ -->
                                                <div class="col-md-6">
                                                    <label asp-for="OtherCost" class="form-label fw-bold">🔧 อื่นๆ (บาท)</label>
                                                    <input asp-for="OtherCost" name="OtherCost" id="OtherCost" class="form-control form-control-lg budget-input-inhouse" type="number" step="0.01" min="0" value="0" style="border-radius: 10px;" />
                                                </div>

                                                <!-- ระบุรายการอื่นๆ -->
                                                <div class="col-md-6">
                                                    <label asp-for="OtherCostDescription" class="form-label fw-bold">📝 ระบุรายการอื่นๆ</label>
                                                    <input asp-for="OtherCostDescription" name="OtherCostDescription" class="form-control form-control-lg" placeholder="กรุณาระบุรายการอื่นๆ" style="border-radius: 10px;" />
                                                </div>

                                                <!-- รวมสุทธิ -->
                                                <!-- รวมสุทธิ (Read-only, คำนวณอัตโนมัติ) -->
                                                <div class="col-12">
                                                    <hr class="my-3">
                                                    <div class="alert alert-success d-flex justify-content-between align-items-center" style="border-radius: 10px;">
                                                        <span class="fw-bold fs-5">💵 รวมสุทธิ (บาท):</span>
                                                        <span class="fw-bold fs-4 text-success" id="totalCostDisplay">0.00</span>
                                                    </div>
                                                    <input asp-for="TotalCost" name="TotalCost" type="hidden" id="totalCostInput" />
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <!-- ปิด row g-3 ที่เริ่มจากบรรทัด 66 -->

                            <!-- 👥 จำนวนผู้เข้าอบรม (แสดงสำหรับทั้ง Public และ In House) -->
                            <div class="row mt-4">
                                <div class="col-12">
                                    <div class="card border-0 shadow-sm" style="border-radius: 12px;">
                                        <div class="card-header bg-primary text-white" style="border-radius: 12px 12px 0 0;">
                                            <h5 class="mb-0 fw-bold">👥 จำนวนผู้เข้าอบรม</h5>
                                        </div>
                                        <div class="card-body p-4">
                                            <div class="row g-3">
                                                <div class="col-md-6">
                                                    <label class="form-label fw-bold">👥 จำนวนผู้เข้าอบรม (คน)</label>
                                                    <input type="number" name="ParticipantCount" id="ParticipantCount" class="form-control form-control-lg" min="1" value="0" style="border-radius: 10px;" />
                                                    <small id="participantCountHelp" class="form-text text-muted">
                                                        <!-- จะแสดง help text ตาม training type -->
                                                    </small>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <script>
                                    // ============================================================
                                    // 🎯 TRAINING REQUEST FORM - FINAL CORRECT VERSION
                                    // ============================================================
                                    document.addEventListener('DOMContentLoaded', function() {
                                        console.log('✅ Training Request Form Script Loaded - Final Correct Version');

                                        // ============================================================
                                        // 📅 STEP 3: จัดการวันที่ด้วย Flatpickr (แสดง dd/mm/yyyy ทุกเครื่อง)
                                        // ============================================================

                                        const startDateInput = document.getElementById('StartDate');
                                        const endDateInput = document.getElementById('EndDate');

                                        // คำนวณวันทำงาน +3 วัน (ข้าม Sunday)
                                        function addWorkingDays(date, days) {
                                            let currentDate = new Date(date);
                                            let addedDays = 0;

                                            while (addedDays < days) {
                                                currentDate.setDate(currentDate.getDate() + 1);
                                                if (currentDate.getDay() !== 0) {
                                                    addedDays++;
                                                }
                                            }

                                            return currentDate;
                                        }

                                        const today = new Date();
                                        const minDate = addWorkingDays(today, 3);

                                        // Flatpickr instances
                                        let fpStart = null;
                                        let fpEnd = null;

                                        if (startDateInput) {
                                            fpStart = flatpickr(startDateInput, {
                                                dateFormat: "Y-m-d",
                                                altInput: true,
                                                altFormat: "d/m/Y",
                                                minDate: minDate,
                                                allowInput: false,
                                                altInputClass: "form-control form-control-lg flatpickr-alt-input",
                                                onChange: function(selectedDates, dateStr) {
                                                    if (dateStr && fpEnd) {
                                                        // ตั้ง min date ของ EndDate = StartDate
                                                        fpEnd.set('minDate', dateStr);
                                                        // ถ้ายังไม่ได้เลือก EndDate → auto fill ให้เท่ากับ StartDate
                                                        if (!fpEnd.selectedDates.length) {
                                                            fpEnd.setDate(dateStr, true);
                                                        }
                                                        // ถ้า EndDate < StartDate → reset
                                                        if (fpEnd.selectedDates.length && fpEnd.selectedDates[0] < selectedDates[0]) {
                                                            fpEnd.setDate(dateStr, true);
                                                        }
                                                    }
                                                    console.log('📅 Start Date Selected:', dateStr);
                                                }
                                            });
                                            console.log('📅 Flatpickr initialized for StartDate, minDate:', minDate.toISOString().split('T')[0]);
                                        }

                                        if (endDateInput) {
                                            fpEnd = flatpickr(endDateInput, {
                                                dateFormat: "Y-m-d",
                                                altInput: true,
                                                altFormat: "d/m/Y",
                                                minDate: minDate,
                                                allowInput: false,
                                                altInputClass: "form-control form-control-lg flatpickr-alt-input",
                                                onChange: function(selectedDates, dateStr) {
                                                    const startVal = startDateInput ? startDateInput.value : '';
                                                    if (startVal && dateStr && dateStr < startVal) {
                                                        alert('⚠️ วันที่สิ้นสุดการอบรมต้องไม่น้อยกว่าวันที่เริ่มอบรม');
                                                        fpEnd.setDate(startVal, true);
                                                    }
                                                    console.log('📅 End Date Selected:', dateStr);
                                                }
                                            });
                                            console.log('📅 Flatpickr initialized for EndDate');
                                        }

                                        // ============================================================
                                        // 🔢 STEP 2: Auto-clear ค่า 0 เมื่อ Focus
                                        // ============================================================

                                        const autoClearInputs = document.querySelectorAll('.budget-input-public, .budget-input-inhouse');

                                        autoClearInputs.forEach(input => {
                                            input.addEventListener('focus', function() {
                                                if (this.value === '0' || this.value === '0.00') {
                                                    this.value = '';
                                                }
                                            });

                                            input.addEventListener('blur', function() {
                                                if (this.value.trim() === '') {
                                                    this.value = '0';
                                                }
                                            });
                                        });

                                        console.log('✅ Auto-clear setup for', autoClearInputs.length, 'inputs');

                                        // ============================================================
                                        // 💰 คำนวณงบประมาณอัตโนมัติ (Public) - นับจำนวนคนจากตาราง
                                        // ============================================================

                                        const costPerPersonPublic = document.getElementById('CostPerPerson');
                                        const totalCostDisplayPublic = document.getElementById('totalCostDisplayPublic');

                                        // ✅ Global function: คำนวณงบประมาณ Public
                                        window.calculateTotalBudgetPublic = function() {
                                            let costPerPerson = parseFloat(costPerPersonPublic?.value) || 0;

                                            // ✅ นับจำนวนคนจากตารางพนักงาน (employeeManager.employees.length)
                                            // ต้องรอจนกว่า employeeManager จะถูก initialize
                                            let participantCount = 0;
                                            if (typeof employeeManager !== 'undefined' && employeeManager.employees) {
                                                participantCount = employeeManager.employees.length;
                                            }

                                            // ✅ คูณ: ค่าใช้จ่ายต่อคน × จำนวนคนในตาราง
                                            let total = costPerPerson * participantCount;

                                            // ✅ อัพเดทการแสดงผล
                                            if (totalCostDisplayPublic) {
                                                totalCostDisplayPublic.textContent = total.toLocaleString('th-TH', {
                                                    minimumFractionDigits: 2,
                                                    maximumFractionDigits: 2
                                                });
                                            }

                                            // ✅ อัพเดท Hidden Input สำหรับส่งไป Backend
                                            const totalCostInput = document.getElementById('totalCostInput');
                                            if (totalCostInput) {
                                                totalCostInput.value = total.toFixed(2);
                                            }

                                            console.log('💰 Total Budget (Public):', {
                                                costPerPerson,
                                                participantCount,
                                                source: 'employeeManager.employees.length',
                                                total: total.toFixed(2),
                                                updatedInput: 'totalCostInput'
                                            });

                                            return total;
                                        };

                                        // ✅ Event Listeners สำหรับ CostPerPerson
                                        if (costPerPersonPublic) {
                                            costPerPersonPublic.addEventListener('input', calculateTotalBudgetPublic);
                                            costPerPersonPublic.addEventListener('change', calculateTotalBudgetPublic);
                                        }

                                        // ============================================================
                                        // 💰 คำนวณงบประมาณอัตโนมัติ (In House) - 6 ช่อง
                                        // ============================================================

                                        const budgetInputsInHouse = document.querySelectorAll('.budget-input-inhouse');
                                        const totalCostDisplayInHouse = document.getElementById('totalCostDisplayInHouse');

                                        function calculateTotalBudgetInHouse() {
                                            let total = 0;

                                            // คำนวณจาก: วิทยากร + คอมแมน + อุปกรณ์ + อาหาร + อื่นๆ
                                            budgetInputsInHouse.forEach(input => {
                                                const value = parseFloat(input.value) || 0;
                                                total += value;
                                            });

                                            if (totalCostDisplayInHouse) {
                                                totalCostDisplayInHouse.textContent = total.toLocaleString('th-TH', {
                                                    minimumFractionDigits: 2,
                                                    maximumFractionDigits: 2
                                                });
                                            }

                                            console.log('💰 Total Budget (In House):', total.toFixed(2));

                                            return total;
                                        }

                                        budgetInputsInHouse.forEach(input => {
                                            input.addEventListener('input', calculateTotalBudgetInHouse);
                                            input.addEventListener('change', calculateTotalBudgetInHouse);
                                        });

                                        // ============================================================
                                        // 🎯 STEP 4: แสดง/ซ่อนกรอบงบประมาณตามประเภทการอบรม
                                        // ============================================================

                                        const budgetPublicCard = document.getElementById('budgetPublicCard');
                                        const budgetInHouseCard = document.getElementById('budgetInHouseCard');
                                        const trainingHistorySection = document.getElementById('trainingHistorySection');
                                        const budgetSourceSection = document.getElementById('budgetSourceSection');
                                        const trainingTypeRadios = document.querySelectorAll('input[name="TrainingType"]');

                                        function toggleBudgetCards() {
                                            const selectedType = document.querySelector('input[name="TrainingType"]:checked');
                                            const participantCountField = document.getElementById('ParticipantCount');
                                            const participantCountHelp = document.getElementById('participantCountHelp');

                                            if (!selectedType) {
                                                if (budgetPublicCard) budgetPublicCard.style.display = 'none';
                                                if (budgetInHouseCard) budgetInHouseCard.style.display = 'none';
                                                if (trainingHistorySection) trainingHistorySection.style.display = 'none';
                                                if (budgetSourceSection) budgetSourceSection.style.display = 'none';
                                                console.log('🔄 No training type selected - hiding all budget cards and training history table');
                                                return;
                                            }

                                            const typeValue = selectedType.value;

                                            if (typeValue === 'Public') {
                                                if (budgetPublicCard) budgetPublicCard.style.display = 'block';
                                                if (budgetInHouseCard) budgetInHouseCard.style.display = 'none';
                                                if (trainingHistorySection) trainingHistorySection.style.display = 'block';
                                                if (budgetSourceSection) budgetSourceSection.style.display = 'block';

                                                // ✅ สำหรับ Public: ตั้งเป็น readonly และแสดง help text
                                                if (participantCountField) {
                                                    participantCountField.setAttribute('readonly', 'readonly');
                                                    participantCountField.style.backgroundColor = '#e9ecef';
                                                    participantCountField.style.cursor = 'not-allowed';
                                                    participantCountField.value = '0';
                                                }
                                                if (participantCountHelp) {
                                                    participantCountHelp.textContent = 'ℹ️ จำนวนผู้เข้าอบรมจะถูกตั้งค่าอัตโนมัติจากจำนวนพนักงานในตาราง';
                                                }

                                                console.log('✅ Showing Public budget card (2 fields) + Training History Table');
                                                calculateTotalBudgetPublic();
                                            } else if (typeValue === 'In House') {
                                                if (budgetPublicCard) budgetPublicCard.style.display = 'none';
                                                if (budgetInHouseCard) budgetInHouseCard.style.display = 'block';
                                                if (trainingHistorySection) trainingHistorySection.style.display = 'none';
                                                // ✅ In House: ซ่อน Radio แหล่งงบ + clear selection
                                                if (budgetSourceSection) budgetSourceSection.style.display = 'none';
                                                const budgetSourceChecked = document.querySelector('input[name="BudgetSource"]:checked');
                                                if (budgetSourceChecked) budgetSourceChecked.checked = false;

                                                // ✅ สำหรับ In House: ให้กรอกได้ปกติ
                                                if (participantCountField) {
                                                    participantCountField.removeAttribute('readonly');
                                                    participantCountField.style.backgroundColor = '';
                                                    participantCountField.style.cursor = '';
                                                    if (participantCountField.value === '0' || !participantCountField.value) {
                                                        participantCountField.value = '1';
                                                    }
                                                }
                                                if (participantCountHelp) {
                                                    participantCountHelp.textContent = 'ℹ️ กรุณากรอกจำนวนผู้เข้าอบรมที่คาดหมาย';
                                                }

                                                console.log('✅ Showing In House budget card (7 fields) + Hiding Training History Table');
                                                calculateTotalBudgetInHouse();
                                            }
                                        }

                                        trainingTypeRadios.forEach(radio => {
                                            radio.addEventListener('change', toggleBudgetCards);
                                        });

                                        toggleBudgetCards();

                                        // ============================================================
                                        // 📋 Form Validation และ Submit
                                        // ============================================================

                                        const form = document.getElementById('trainingRequestForm');

                                        if (form) {
                                            form.addEventListener('submit', function(e) {
                                                console.log('📝 Form Submit Started');

                                                const errors = [];

                                                const companyRadio = document.querySelector('input[name="Company"]:checked');
                                                if (!companyRadio) {
                                                    errors.push('กรุณาเลือกบริษัท');
                                                }

                                                const trainingTypeRadio = document.querySelector('input[name="TrainingType"]:checked');
                                                if (!trainingTypeRadio) {
                                                    errors.push('กรุณาเลือกประเภทการอบรม');
                                                }

                                                const startDate = startDateInput ? startDateInput.value : '';
                                                const endDate = endDateInput ? endDateInput.value : '';

                                                if (!startDate) {
                                                    errors.push('กรุณาเลือกวันที่เริ่มอบรม');
                                                }

                                                if (!endDate) {
                                                    errors.push('กรุณาเลือกวันที่สิ้นสุดการอบรม');
                                                }

                                                if (startDate && endDate && endDate < startDate) {
                                                    errors.push('วันที่สิ้นสุดต้องไม่น้อยกว่าวันที่เริ่ม');
                                                }

                                                const seminarTitle = document.getElementById('SeminarTitle');
                                                if (seminarTitle && !seminarTitle.value.trim()) {
                                                    errors.push('กรุณากรอกเรื่องสัมมนา');
                                                }

                                                const trainingLocation = document.getElementById('TrainingLocation');
                                                if (trainingLocation && !trainingLocation.value.trim()) {
                                                    errors.push('กรุณากรอกสถานที่อบรม');
                                                }

                                                if (errors.length > 0) {
                                                    e.preventDefault();
                                                    alert('⚠️ กรุณาแก้ไขข้อผิดพลาด:\n\n' + errors.join('\n'));
                                                    console.error('❌ Form validation failed:', errors);
                                                    return false;
                                                }

                                                const selectedType = document.querySelector('input[name="TrainingType"]:checked');
                                                if (selectedType && selectedType.value === 'Public') {
                                                    calculateTotalBudgetPublic();
                                                } else if (selectedType && selectedType.value === 'In House') {
                                                    calculateTotalBudgetInHouse();
                                                }

                                                console.log('✅ Form validation passed');
                                                console.log('📤 Submitting form...');

                                                return true;
                                            });
                                        }

                                        // ============================================================
                                        // ✅ สรุปการโหลด
                                        // ============================================================

                                        console.log('===========================================');
                                        console.log('✅ FINAL CORRECT VERSION LOADED');
                                        console.log('===========================================');
                                        console.log('🔵 Public: 2 fields (ค่าต่อคน + ชั่วโมง)');
                                        console.log('🟡 In House: 7 fields');
                                        console.log('   1. ค่าวิทยากร');
                                        console.log('   2. ค่าคอมแมนวิทยากร ✅');
                                        console.log('   3. ค่าอุปกรณ์');
                                        console.log('   4. ค่าอาหาร');
                                        console.log('   5. อื่นๆ');
                                        console.log('   6. ระบุรายการอื่นๆ');
                                        console.log('   7. จำนวนผู้เข้าอบรม ✅');
                                        console.log('===========================================');
                                        console.log('✅ ฝ่าย/แผนก: Dropdown (รอข้อมูลจาก Backend)');
                                        console.log('✅ Auto-clear Zero - Ready');
                                        console.log('✅ Smart Date Handling - Ready');
                                        console.log('✅ Show/Hide Budget Cards - Ready');
                                        console.log('===========================================');
                                    });
                                </script>

