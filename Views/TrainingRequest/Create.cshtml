                                <script>
                                    // Show/Hide KM Section based on TrainingType
                                    document.addEventListener('DOMContentLoaded', function () {
                                        function toggleKMSection() {
                                            var selectedType = document.querySelector('input[name="TrainingType"]:checked');
                                            var kmSection = document.getElementById('kmSection');
                                            if (selectedType && selectedType.value === 'Public') {
                                                kmSection.style.display = 'block';
                                            } else {
                                                kmSection.style.display = 'none';
                                            }
                                        }

                                        document.querySelectorAll('input[name="TrainingType"]').forEach(function (radio) {
                                            radio.addEventListener('change', toggleKMSection);
                                        });

                                        // ✅ Flatpickr สำหรับ KM date fields
                                        var fpKmCreate = flatpickr('#kmCreateReportDate', {
                                            dateFormat: "Y-m-d",
                                            altInput: true,
                                            altFormat: "d/m/Y",
                                            allowInput: false,
                                            altInputClass: "form-control flatpickr-alt-input"
                                        });
                                        // ตั้ง disabled ให้ alt input ตอนเริ่มต้น
                                        if (fpKmCreate.altInput) fpKmCreate.altInput.disabled = true;

                                        var fpKmSharing = flatpickr('#kmKnowledgeSharingDate', {
                                            dateFormat: "Y-m-d",
                                            altInput: true,
                                            altFormat: "d/m/Y",
                                            allowInput: false,
                                            altInputClass: "form-control flatpickr-alt-input"
                                        });
                                        if (fpKmSharing.altInput) fpKmSharing.altInput.disabled = true;

                                        // Enable/Disable date fields based on checkbox
                                        document.getElementById('kmCreateReport').addEventListener('change', function () {
                                            var el = document.getElementById('kmCreateReportDate');
                                            el.disabled = !this.checked;
                                            if (el._flatpickr && el._flatpickr.altInput) {
                                                el._flatpickr.altInput.disabled = !this.checked;
                                            }
                                            if (!this.checked && el._flatpickr) {
                                                el._flatpickr.clear();
                                            }
                                        });

                                        document.getElementById('kmKnowledgeSharing').addEventListener('change', function () {
                                            var el = document.getElementById('kmKnowledgeSharingDate');
                                            el.disabled = !this.checked;
                                            if (el._flatpickr && el._flatpickr.altInput) {
                                                el._flatpickr.altInput.disabled = !this.checked;
                                            }
                                            if (!this.checked && el._flatpickr) {
                                                el._flatpickr.clear();
                                            }
                                        });

                                        // Initial check
                                        toggleKMSection();
                                    });
                                </script>

