    // ✅ ฟังก์ชันดึงข้อมูล Department
    async function loadDepartments() {
        try {
            const response = await fetch('/api/employees/departments');
            if (!response.ok) {
                throw new Error('Failed to load departments');
            }

            const departments = await response.json();
            const departmentSelect = document.getElementById('departmentSelect');

            // เคลียร์ options เดิม (เก็บเฉพาะ option แรก)
            departmentSelect.innerHTML = '<option value="">-- เลือกฝ่าย --</option>';

            // เพิ่ม options จาก API
            departments.forEach(dept => {
                const option = document.createElement('option');
                option.value = dept;
                option.textContent = dept;
                departmentSelect.appendChild(option);
            });

            console.log('✅ โหลด Departments สำเร็จ:', departments.length, 'รายการ');

        } catch (error) {
            console.error('❌ Error loading departments:', error);
            alert('⚠️ ไม่สามารถโหลดข้อมูลฝ่ายได้ กรุณาลองใหม่อีกครั้ง');
        }
    }

    // ✅ Event: เมื่อเลือก Department ให้โหลด Position และ reset ผู้อนุมัติ
    document.getElementById('departmentSelect').addEventListener('change', async function() {
        const department = this.value;
        const positionSelect = document.getElementById('positionSelect');

        // ✅ Reset Section Manager และ Department Manager
        $('#sectionManagerSelect').val(null).trigger('change');
        $('#departmentManagerSelect').val(null).trigger('change');
        $('#sectionManagerIdHidden').val('');
        $('#departmentManagerIdHidden').val('');
        console.log('🔄 Reset Section Manager และ Department Manager');

        // ถ้าไม่เลือกฝ่าย ให้ disable Position dropdown
        if (!department) {
            positionSelect.disabled = true;
            positionSelect.innerHTML = '<option value="">-- เลือกฝ่ายก่อน --</option>';
            return;
        }

        try {
            // แสดง Loading
            positionSelect.innerHTML = '<option value="">กำลังโหลด...</option>';
            positionSelect.disabled = true;

            // โหลด Positions ตาม Department ที่เลือก
            const response = await fetch(`/api/employees/positions?department=${encodeURIComponent(department)}`);

            if (!response.ok) {
                throw new Error('Failed to load positions');
            }

            const positions = await response.json();

            // เคลียร์และเพิ่ม options ใหม่
            positionSelect.innerHTML = '<option value="">-- เลือกแผนก --</option>';

            if (positions.length === 0) {
                positionSelect.innerHTML = '<option value="">-- ไม่มีแผนกในฝ่ายนี้ --</option>';
                positionSelect.disabled = true;
                console.warn('⚠️ ไม่พบแผนกในฝ่าย:', department);
                return;
            }

            positions.forEach(pos => {
                const option = document.createElement('option');
                option.value = pos;
                option.textContent = pos;
                positionSelect.appendChild(option);
            });

            // เปิดใช้งาน dropdown
            positionSelect.disabled = false;

            console.log('✅ โหลด Positions สำเร็จ:', positions.length, 'รายการ');

        } catch (error) {
            console.error('❌ Error loading positions:', error);
            positionSelect.innerHTML = '<option value="">-- เกิดข้อผิดพลาด --</option>';
            positionSelect.disabled = true;
            alert('⚠️ ไม่สามารถโหลดข้อมูลแผนกได้ กรุณาลองใหม่อีกครั้ง');
        }
    });

    // ✅ Event: เมื่อเลือก Position ให้ reset ผู้อนุมัติ
    document.getElementById('positionSelect').addEventListener('change', function() {
        // ✅ Reset Section Manager และ Department Manager
        $('#sectionManagerSelect').val(null).trigger('change');
        $('#departmentManagerSelect').val(null).trigger('change');
        $('#sectionManagerIdHidden').val('');
        $('#departmentManagerIdHidden').val('');
        console.log('🔄 Reset Section Manager และ Department Manager (Position changed)');
    });

    // ====================================================================
    // Step 2: Form Submit Handler (ป้องกันการทำงานซ้ำ)
    // ====================================================================
    (function() {
        'use strict';

        console.log('🔧 Setting up form submit handler...');

        const form = document.querySelector('form[method="post"]');

        if (!form) {
            console.error('❌ Form not found!');
            return;
        }

        // ✅ ป้องกันการ submit ซ้ำ
        let isSubmitting = false;

        console.log('✅ Form found');

        // ✅ ใช้ addEventListener แบบไม่ซ้ำ
        form.addEventListener('submit', async function(e) {
            // ⭐ ป้องกัน default behavior ทันที
            e.preventDefault();
            e.stopPropagation();
            e.stopImmediatePropagation();

            // ⭐ ตรวจสอบว่ากำลัง submit อยู่หรือไม่
            if (isSubmitting) {
                console.warn('⚠️ Already submitting, ignoring duplicate submit');
                return false;
            }

            isSubmitting = true;
            console.log('🔵 Form submit triggered!');

            try {
                // ====================================================================
                // Validation
                // ====================================================================

                const company = document.querySelector('input[name="Company"]:checked');
                if (!company) {
                    alert('❌ กรุณาเลือกบริษัท');
                    isSubmitting = false;
                    return false;
                }

                const trainingType = document.querySelector('input[name="TrainingType"]:checked');
                if (!trainingType) {
                    alert('❌ กรุณาเลือกประเภทการอบรม');
                    isSubmitting = false;
                    return false;
                }

                const startDate = document.querySelector('input[name="StartDate"]');
                const endDate = document.querySelector('input[name="EndDate"]');

                if (!startDate || !startDate.value) {
                    alert('❌ กรุณาระบุวันที่เริ่มอบรม');
                    isSubmitting = false;
                    return false;
                }

                if (!endDate || !endDate.value) {
                    alert('❌ กรุณาระบุวันที่สิ้นสุดการอบรม');
                    isSubmitting = false;
                    return false;
                }

                // ====================================================================
                // Validation ตาม TrainingType
                // ====================================================================

                const trainingTypeValue = trainingType.value;

                if (trainingTypeValue === 'Public') {
                    // ตรวจสอบฟิลด์สำหรับ Public
                    const costPerPerson = document.getElementById('CostPerPerson');
                    const trainingHours = document.getElementById('TrainingHours');

                    if (!costPerPerson || !costPerPerson.value || parseFloat(costPerPerson.value) <= 0) {
                        alert('❌ กรุณากรอกค่าใช้จ่ายต่อคนสำหรับ Public Training');
                        isSubmitting = false;
                        costPerPerson?.focus();
                        return false;
                    }

                    if (!trainingHours || !trainingHours.value || parseFloat(trainingHours.value) <= 0) {
                        alert('❌ กรุณากรอกจำนวนชั่วโมงการอบรมสำหรับ Public Training');
                        isSubmitting = false;
                        trainingHours?.focus();
                        return false;
                    }

                    console.log('✅ Public Training validation passed');

                } else if (trainingTypeValue === 'In House') {
                    console.log('✅ In House Training No required fields validation');
                }

                // ====================================================================
                // Validation ผู้อนุมัติทั้งหมด (บังคับ)
                // ====================================================================

                console.log('🔍 Validating approvers...');

                const sectionManagerId = document.getElementById('sectionManagerIdHidden');
                if (!sectionManagerId || !sectionManagerId.value) {
                    alert('❌ กรุณาเลือก Section Manager\n\nผู้อนุมัติระดับที่ 1');
                    isSubmitting = false;
                    return false;
                }

                const departmentManagerId = document.getElementById('departmentManagerIdHidden');
                if (!departmentManagerId || !departmentManagerId.value) {
                    alert('❌ กรุณาเลือก Department Manager\n\nผู้อนุมัติระดับที่ 2');
                    isSubmitting = false;
                    return false;
                }

                const managingDirectorId = document.getElementById('managingDirectorIdHidden');
                if (!managingDirectorId || !managingDirectorId.value) {
                    alert('❌ กรุณาเลือก Managing Director\n\nผู้อนุมัติระดับที่ 5');
                    isSubmitting = false;
                    return false;
                }

                const hrdAdminId = document.getElementById('hrdAdminIdHidden');
                if (!hrdAdminId || !hrdAdminId.value) {
                    alert('❌ ไม่พบข้อมูล HRD Admin\n\nผู้อนุมัติระดับที่ 3\n\nกรุณารีเฟรชหน้าหรือติดต่อผู้ดูแลระบบ');
                    isSubmitting = false;
                    return false;
                }

                const hrdConfirmationId = document.getElementById('hrdConfirmationIdHidden');
                if (!hrdConfirmationId || !hrdConfirmationId.value) {
                    alert('❌ ไม่พบข้อมูล HRD Confirmation\n\nผู้อนุมัติระดับที่ 4\n\nกรุณารีเฟรชหน้าหรือติดต่อผู้ดูแลระบบ');
                    isSubmitting = false;
                    return false;
                }

                console.log('✅ All approvers validation passed:');
                console.log('  - Section Manager:', sectionManagerId.value);
                console.log('  - Department Manager:', departmentManagerId.value);
                console.log('  - HRD Admin:', hrdAdminId.value);
                console.log('  - HRD Confirmation:', hrdConfirmationId.value);
                console.log('  - Managing Director:', managingDirectorId.value);

                // ====================================================================
                // ดึงข้อมูลพนักงาน
                // ====================================================================

                console.log('👥 Getting employees data...');
                const employeesData = employeeManager.getEmployeesData();
                console.log('👥 Employees count:', employeesData.length);

                // ✅ ถาม confirm เฉพาะ Public Training (In House ไม่จำเป็นต้องมีรายชื่อพนักงาน)
                if (employeesData.length === 0 && trainingTypeValue === 'Public') {
                    const confirmSubmit = confirm('⚠️ ยังไม่มีพนักงานในรายการ\n\nต้องการบันทึกต่อไปหรือไม่?');
                    if (!confirmSubmit) {
                        console.log('❌ User cancelled');
                        isSubmitting = false;
                        return false;
                    }
                }

                // ====================================================================
                // สร้าง FormData
                // ====================================================================

                const formData = new FormData(form);

                // ⭐ แก้ไข: ลบไฟล์เดิมและเพิ่มไฟล์ทุกไฟล์ที่เลือก (เพื่อรองรับ multiple files)
                formData.delete('AttachedFiles');
                const fileInput = document.getElementById('AttachedFiles');
                if (fileInput && fileInput.files.length > 0) {
                    console.log(`📎 Attaching ${fileInput.files.length} file(s)`);
                    for (let i = 0; i < fileInput.files.length; i++) {
                        formData.append('AttachedFiles', fileInput.files[i]);
                        console.log(`  📄 File ${i + 1}: ${fileInput.files[i].name}`);
                    }
                }

                formData.append('EmployeesJson', JSON.stringify(employeesData));

                console.log('📦 FormData prepared');
                console.log('📄 EmployeesJson:', employeesData);

                // ====================================================================
                // ส่งข้อมูลไป Backend
                // ====================================================================

                const submitBtn = form.querySelector('button[type="submit"]');
                const originalHTML = submitBtn.innerHTML;

                submitBtn.disabled = true;
                submitBtn.innerHTML = '<i class="fas fa-spinner fa-spin me-2"></i>กำลังบันทึก...';

                console.log('🚀 Sending to /TrainingRequest/SaveTrainingRequest');

                const response = await fetch('/TrainingRequest/SaveTrainingRequest', {
                    method: 'POST',
                    body: formData
                });

                console.log('📥 Response status:', response.status);

                if (!response.ok) {
                    const errorText = await response.text();
                    console.error('❌ Response error:', errorText);
                    throw new Error(`Server error: ${response.status}`);
                }

                const result = await response.json();
                console.log('📥 Response:', result);

                if (result.success) {
                    console.log('✅ Save successful!');
                    alert(`✅ ${result.message}\n\n📄 เลขที่เอกสาร: ${result.docNo}`);

                    // Redirect to ApprovalFlow page
                    setTimeout(() => {
                        window.location.href = `/TrainingRequest/ApprovalFlow?docNo=${result.docNo}`;
                    }, 500);

                } else {
                    alert('❌ ' + result.message);
                    submitBtn.disabled = false;
                    submitBtn.innerHTML = originalHTML;
                    isSubmitting = false;
                }

            } catch (error) {
                console.error('❌ Error:', error);
                alert('❌ เกิดข้อผิดพลาด:\n\n' + error.message);

                const submitBtn = form.querySelector('button[type="submit"]');
                if (submitBtn) {
                    submitBtn.disabled = false;
                    submitBtn.innerHTML = '💾 บันทึก';
                }
                isSubmitting = false;
            }

            return false;

        }, { once: false, capture: true }); // ⭐ ใช้ capture phase

        console.log('✅ Form submit handler installed!');

        // ====================================================================
        // 🆕 ดึงข้อมูล HRD Admin และ HRD Confirmation อัตโนมัติ
        // ====================================================================
        async function loadHRDApprovers() {
            try {
                console.log('🔄 Loading HRD Approvers...');

                // ดึง HRD Admin (UserID = 7777777)
                const hrdAdminResponse = await fetch('/api/employees/by-userid?userId=7777777');
                const hrdAdminData = await hrdAdminResponse.json();

                if (hrdAdminData.success) {
                    const displayText = `${hrdAdminData.fullName} (${hrdAdminData.email})`;
                    $('#hrdAdminDisplay').val(displayText);
                    $('#hrdAdminIdHidden').val(hrdAdminData.email);
                    console.log('✅ HRD Admin loaded:', hrdAdminData.email);
                } else {
                    $('#hrdAdminDisplay').val('ไม่พบข้อมูล HRD Admin (UserID: 7777777)');
                    $('#hrdAdminIdHidden').val('');
                    console.warn('⚠️ HRD Admin not found:', hrdAdminData.message);
                }

                // ดึง HRD Confirmation (UserID = 8888888)
                const hrdConfirmationResponse = await fetch('/api/employees/by-userid?userId=8888888');
                const hrdConfirmationData = await hrdConfirmationResponse.json();

                if (hrdConfirmationData.success) {
                    const displayText = `${hrdConfirmationData.fullName} (${hrdConfirmationData.email})`;
                    $('#hrdConfirmationDisplay').val(displayText);
                    $('#hrdConfirmationIdHidden').val(hrdConfirmationData.email);
                    console.log('✅ HRD Confirmation loaded:', hrdConfirmationData.email);
                } else {
                    $('#hrdConfirmationDisplay').val('ไม่พบข้อมูล HRD Confirmation (UserID: 8888888)');
                    $('#hrdConfirmationIdHidden').val('');
                    console.warn('⚠️ HRD Confirmation not found:', hrdConfirmationData.message);
                }
            } catch (error) {
                console.error('❌ Error loading HRD Approvers:', error);
                $('#hrdAdminDisplay').val('เกิดข้อผิดพลาดในการโหลด');
                $('#hrdConfirmationDisplay').val('เกิดข้อผิดพลาดในการโหลด');
                $('#hrdAdminIdHidden').val('');
                $('#hrdConfirmationIdHidden').val('');
            }
        }

        // เรียกใช้งานเมื่อหน้าโหลดเสร็จ
        $(document).ready(function() {
            loadHRDApprovers();
        });

    })();
</script>